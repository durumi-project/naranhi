# 「나란히」 환경 변수 템플릿
#
# 사용법:
#   1. 이 파일을 .env.local로 복사:  cp .env.example .env.local
#   2. .env.local 에서 your_key_here 자리에 실제 키 입력
#   3. .env.local 은 .gitignore 에 등록돼 있어 커밋되지 않음
#
# 절대 .env.local 을 git에 커밋하지 말 것 — API 키 노출 사고로 이어짐.

# Anthropic API 키 (Claude API 호출용)
# 발급: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_key_here
