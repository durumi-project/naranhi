\f1\b0 \uc0\u8232 
\f0\b \uc0\u54788 \u51116  \u51208 \u52264  \u45800 \u44228 : \u54617 \u54253 \u50948  \u49900 \u51032  \u51652 \u54665  \u51473 
\f1\b0 \
\uc0\u52488 \u46321 \u54617 \u44368  5\u54617 \u45380  \u50864 \u51652 \u51008  \u53360  \u49548 \u47532 \u50640  \u50696 \u48124 \u54616 \u44256 , \u44049 \u51089 \u49828 \u47084 \u50868  \u51088 \u44537 \u51012  \u48155 \u51004 \u47732  \u44480 \u47484  \u47561 \u45716  \u54665 \u46041 \u51012  \u54620 \u45796 . \u52376 \u51020 \u50640 \u45716  \u49688 \u50629  \u51473  \u51032 \u51088 \u44032  \u45132 \u47532 \u45716  \u49548 \u47532 \u50640  \u50864 \u51652 \u51060  \u44480 \u47484  \u47561 \u51088  \u47751 \u47751  \u54617 \u49373 \u46308 \u51060  \u50883 \u50632 \u45796 . \u45796 \u51020  \u45216 \u48512 \u53552  \u44536  \u54617 \u49373 \u46308 \u51008  \u51068 \u48512 \u47084  \u50864 \u51652  \u50694 \u50640 \u49436  \u52293 \u49345 \u51012  \u49464 \u44172  \u52824 \u44144 \u45208  \u54596 \u53685 \u51012  \u46504 \u50612 \u46888 \u47160 \u45796 .\
\uc0\u50864 \u51652 \u51060  \u44480 \u47484  \u47561 \u51004 \u47732  \'93\u46608  \u44256 \u51109 \u45228 \u45796 \'94, \'93\u49548 \u47532  \u48260 \u53948  \u45580 \u47104 \u45796 \'94\u44256  \u47568 \u54664 \u45796 . \u47784 \u46176 \u54876 \u46041  \u46412 \u46020  \'93\u51172 \u46993  \u54616 \u47732  \u45712 \u47140 \u51652 \u45796 \'94\u47728  \u50864 \u51652 \u51012  \u48176 \u51228 \u54664 \u45796 . \u50612 \u45712  \u45216  \u54620  \u54617 \u49373 \u51060  \u50864 \u51652 \u51032  \u48152 \u51025 \u51012  \u55092 \u45824 \u54256 \u51004 \u47196  \u52237 \u51004 \u47140  \u54616 \u51088  \u50864 \u51652 \u51008  \u53356 \u44172  \u49548 \u47532 \u47484  \u51648 \u47476 \u47728  \u52293 \u49345  \u48145 \u51004 \u47196  \u46308 \u50612 \u44052 \u45796 . \u45812 \u51076 \u44368 \u49324 \u45716  \u50864 \u51652 \u51060  \u49688 \u50629  \u52280 \u50668 \u47484  \u44144 \u48512 \u54616 \u45716  \u51068 \u51060  \u45720 \u51088  \u49345 \u45812 \u51012  \u51652 \u54665 \u54664 \u44256 , \u50864 \u51652 \u51008  \'93\u50528 \u46308 \u51060  \u51068 \u48512 \u47084  \u49548 \u47532 \u47484  \u45240 \u45796 \'94\u44256  \u47568 \u54664 \u45796 .\
\uc0\u54617 \u44368 \u45716  \u49324 \u50504 \u51012  \u51217 \u49688 \u54620  \u46244  \u51204 \u45812 \u44592 \u44396  \u51312 \u49324 \u47484  \u51652 \u54665 \u54664 \u44256 , \u54788 \u51116  \u49900 \u51032 \u50948 \u50896 \u54924 \u44032  \u50676 \u47532 \u44256  \u51080 \u45796 . \u44032 \u54644  \u44288 \u47144 \u54617 \u49373  \u52769 \u51008  \'93\u51109 \u45212 \u51060 \u50632 \u44256  \u50864 \u51652 \u51060  \u45320 \u47924  \u50696 \u48124 \u54616 \u44172  \u48152 \u51025 \u54664 \u45796 \'94\u44256  \u51452 \u51109 \u54616 \u44256  \u51080 \u45796 . \u44536 \u47084 \u45208  \u51060  \u49324 \u44148 \u51032  \u54645 \u49900 \u51008  \u50864 \u51652 \u51032  \u53945 \u49457 \u51012  \u50508 \u44256 \u46020  \u48152 \u48373 \u51201 \u51004 \u47196  \u51088 \u44537 \u54616 \u44256  \u51312 \u47217 \u54664 \u45796 \u45716  \u51216 \u51060 \u45796 .\
