\f1\b0 \
\uc0\u51473 \u54617 \u44368  1\u54617 \u45380  \u54788 \u49436 \u45716  \u46041 \u50500 \u47532  \u54876 \u46041 \u51012  \u54616 \u47732 \u49436  3\u54617 \u45380  \u49440 \u48176 \u46308 \u44284  \u44032 \u44620 \u50892 \u51276 \u45796 . \u52376 \u51020 \u50640 \u45716  \u49440 \u48176 \u46308 \u51060  \u52828 \u51208 \u54616 \u44172  \u45824 \u54644 \u51452 \u45716  \u44163  \u44057 \u50520 \u45796 . \u54616 \u51648 \u47564  \u49884 \u44036 \u51060  \u51648 \u45208 \u51088  \u49440 \u48176 \u46308 \u51008  \u54788 \u49436 \u50640 \u44172  \u51020 \u47308 \u49688 \u47484  \u49324 \u50724 \u46972 \u44256  \u54616 \u44144 \u45208 , \u46041 \u50500 \u47532 \u49892  \u52397 \u49548 \u47484  \u54844 \u51088  \u54616 \u44172  \u54664 \u45796 .\
\uc0\u50612 \u45712  \u45216  \u49440 \u48176 \u45716  \'93\u49373 \u51068 \u51064 \u45936  \u44592 \u54532 \u54000 \u53080  \u54616 \u45208  \u48372 \u45236 \u46972 \'94\u44256  \u54664 \u45796 . \u54788 \u49436 \u44032  \u46024 \u51060  \u50630 \u45796 \u44256  \u54616 \u51088  \'93\u54980 \u48176 \u44032  \u44536  \u51221 \u46020 \u46020  \u47803  \u54616 \u45264 \'94\u44256  \u54664 \u44256 , \u45796 \u47480  \u49440 \u48176 \u46308 \u46020  \u52292 \u54021 \u48169 \u50640 \u49436  \u54788 \u49436 \u47484  \u50517 \u48149 \u54664 \u45796 . \u54788 \u49436 \u45716  \u54200 \u51032 \u51216  \u44592 \u54532 \u54000 \u53080 \u51012  \u50668 \u47084  \u48264  \u48372 \u45256 \u44256 , \u46041 \u50500 \u47532  \u48156 \u54364  \u51088 \u47308 \u46020  \u45824 \u49888  \u47564 \u46308 \u50632 \u45796 . \u44144 \u51208 \u54616 \u47732  \u46041 \u50500 \u47532 \u50640 \u49436  \u49548 \u50808 \u46112  \u44163  \u44057 \u50500  \u44228 \u49549  \u50836 \u44396 \u47484  \u46308 \u50612 \u51452 \u50632 \u45796 .\
\uc0\u48372 \u54840 \u51088 \u45716  \u54788 \u49436 \u51032  \u44208 \u51228  \u45236 \u50669 \u44284  \u52292 \u54021 \u48169  \u47700 \u49884 \u51648 \u47484  \u54869 \u51064 \u54616 \u44256  \u54617 \u44368 \u50640  \u49888 \u44256 \u54664 \u45796 . \u54788 \u51116  \u49900 \u51032 \u50948 \u50896 \u54924 \u44032  \u51068 \u51452 \u51068  \u46244 \u47196  \u50696 \u51221 \u46104 \u50612  \u51080 \u45796 . \u54788 \u49436  \u52769 \u51008  \u44592 \u54532 \u54000 \u53080  \u44208 \u51228  \u45236 \u50669 , \u52292 \u54021 \u48169  \u52897 \u52376 , \u46041 \u50500 \u47532 \u49892  \u52397 \u49548 \u47484  \u54844 \u51088  \u54664 \u45796 \u45716  \u52828 \u44396  \u51652 \u49696 \u51012  \u51221 \u47532 \u54616 \u44256  \u51080 \u45796 . \u51060  \u49324 \u44148 \u51008  \u49440 \u54980 \u48176  \u44288 \u44228 \u47484  \u51060 \u50857 \u54620  \u44053 \u50836 \u50752  \u44552 \u54408  \u50836 \u44396 \u44032  \u54645 \u49900 \u51060 \u45796 .\
