\f0\b \uc0\u54788 \u51116  \u51208 \u52264  \u45800 \u44228 : \u48120 \u51064 \u51648 \'b7\u48120 \u49888 \u44256 
\f1\b0 \
\uc0\u51473 \u54617 \u44368  1\u54617 \u45380  \u49688 \u50500 \u45716  \u53412 \u44032  \u51089 \u44256  \u52404 \u44201 \u51060  \u50780 \u49548 \u54664 \u45796 . 3\u50900  \u52488  \u44057 \u51008  \u48152  \u54617 \u49373 \u46308 \u51060  \u49688 \u50500 \u50640 \u44172  \'93\u52488 \u46321 \u54617 \u49373  \u44057 \u45796 \'94, \'93\u44553 \u49885  \u47673 \u50612 \u46020  \u50504  \u53356 \u45264 \'94\u45716  \u47568 \u51012  \u54616 \u44592  \u49884 \u51089 \u54664 \u45796 . \u49688 \u50500 \u45716  \u52376 \u51020 \u50640 \u45716  \u50883 \u50612 \u45336 \u44220 \u51648 \u47564 , \u51060 \u47088  \u47568 \u51008  \u47588 \u51068  \u48152 \u48373 \u46104 \u50632 \u45796 .\
\uc0\u44553 \u49885 \u49892 \u50640 \u49436 \u45716  \u45908  \u45432 \u44264 \u51201 \u51064  \u51068 \u51060  \u48268 \u50612 \u51276 \u45796 . \u49688 \u50500 \u44032  \u49885 \u54032 \u51012  \u46308 \u44256  \u50724 \u47732  \u47751 \u47751  \u54617 \u49373 \u46308 \u51060  \'93\u50528 \u44592  \u51032 \u51088  \u54596 \u50836 \u54616 \u45264 \'94\u44256  \u54664 \u44256 , \u49688 \u50500 \u44032  \u48165 \u51012  \u51312 \u44552  \u45224 \u44592 \u47732  \'93\u44536 \u47084 \u45768 \u44620  \u50504  \u53356 \u51648 \'94\u46972 \u44256  \u47568 \u54664 \u45796 . \u44057 \u51008  \u48152  \u52828 \u44396 \u46308 \u51008  \u51649 \u51217  \u50837 \u51012  \u54616 \u51648 \u45716  \u50506 \u50520 \u51648 \u47564 , \u44536  \u47568 \u51012  \u46307 \u44256  \u50883 \u44144 \u45208  \u47784 \u47480  \u52377 \u54664 \u45796 . \u49688 \u50500 \u45716  \u51216 \u51216  \u44553 \u49885 \u49892 \u50640  \u44032 \u44592  \u49899 \u50612 \u51276 \u44256 , \u51216 \u49900 \u51012  \u44144 \u51032  \u47673 \u51648  \u50506 \u44172  \u46104 \u50632 \u45796 .\
\uc0\u54788 \u51116  \u49688 \u50500 \u45716  \u50500 \u51649  \u54617 \u44368 \u50640  \u51060  \u49324 \u49892 \u51012  \u50508 \u47532 \u51648  \u50506 \u50520 \u45796 . \u48372 \u54840 \u51088 \u46020  \u49688 \u50500 \u44032  \u51216 \u49900 \u51012  \u44144 \u47476 \u45716  \u51060 \u50976 \u47484  \u51221 \u54869 \u55176  \u47784 \u47480 \u45796 . \u51060  \u45800 \u44228 \u45716  
\f0\b \uc0\u48120 \u51064 \u51648 \'b7\u48120 \u49888 \u44256 
