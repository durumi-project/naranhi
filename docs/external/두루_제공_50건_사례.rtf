\f0\b\fs36 \cf2 \strokec2 4. \uc0\u50868 \u46041 \u48512  \u49440 \u48176 \u51032  \u44592 \u54633 \u44284  \u54253 \u54665 \
\pard\pardeftab720\sa240\partightenfactor0

\fs24 \cf2 \uc0\u52852 \u53580 \u44256 \u47532 : \u49888 \u52404 \u54253 \u47141 , \u50868 \u46041 \u48512  \u50948 \u44228 \u54253 \u47141 , \u44053 \u50836 
\f1\b0 \uc0\u8232 
\f0\b \uc0\u54788 \u51116  \u51208 \u52264  \u45800 \u44228 : \u54617 \u54253 \u50948  \u49900 \u51032  \u53685 \u48372 
\f1\b0 \
\uc0\u44256 \u46321 \u54617 \u44368  1\u54617 \u45380  \u51456 \u54840 \u45716  \u50556 \u44396 \u48512 \u50640  \u46308 \u50612 \u44036  \u46244  \u49440 \u48176 \u46308 \u51032  \u49900 \u48512 \u47492 \u51012  \u45817 \u50672 \u54620  \u47928 \u54868 \u52376 \u47100  \u48155 \u50500 \u46308 \u50688 \u45796 . \u52376 \u51020 \u50640 \u45716  \u47932 \u53685  \u52292 \u50864 \u44592 , \u51109 \u48708  \u51221 \u47532 , \u50556 \u49885  \u49324 \u50724 \u44592  \u51221 \u46020 \u50688 \u45796 . \u44536 \u47084 \u45208  \u50672 \u49845 \u44221 \u44592 \u50640 \u49436  \u49892 \u49688 \u47484  \u54620  \u45216 \u48512 \u53552  \u49440 \u48176 \u46308 \u51032  \u53468 \u46020 \u44032  \u45804 \u46972 \u51276 \u45796 . \u54620  \u49440 \u48176 \u45716  \u51456 \u54840 \u50640 \u44172  \'93\u45320  \u46412 \u47928 \u50640  \u54016  \u48516 \u50948 \u44592  \u47581 \u54664 \u45796 \'94\u47728  \u47784 \u46160  \u50526 \u50640 \u49436  \u50837 \u49444 \u51012  \u54664 \u44256 , \u54984 \u47144 \u51060  \u45149 \u45212  \u46244  \u51456 \u54840 \u50640 \u44172 \u47564  \u52628 \u44032  \u47084 \u45789 \u51012  \u49884 \u53040 \u45796 .\
\uc0\u46972 \u52964 \u47352 \u50640 \u49436 \u45716  \u50612 \u44648 \u47484  \u48128 \u52824 \u44144 \u45208  \u54764 \u47719 \u51004 \u47196  \u47672 \u47532 \u47484  \u52824 \u45716  \u51068 \u46020  \u51080 \u50632 \u45796 . \u51456 \u54840 \u44032  \u49552 \u47785  \u53685 \u51613 \u51012  \u54840 \u49548 \u54616 \u51088  \u49440 \u48176 \u46308 \u51008  \'93\u44928 \u48337  \u48512 \u47532 \u51648  \u47560 \'94\u46972 \u44256  \u54664 \u44256 , \u53076 \u52824 \u44032  \u50630 \u45716  \u49884 \u44036 \u50640  1\u54617 \u45380 \u46308 \u50640 \u44172  \u45800 \u52404  \u44592 \u54633 \u51012  \u51452 \u50632 \u45796 . \u51456 \u54840 \u44032  \u50612 \u51648 \u47084 \u50892  \u51452 \u51200 \u50505 \u51088  \u45796 \u47480  \u54617 \u49373 \u51060  \u48372 \u44148 \u44368 \u49324 \u50640 \u44172  \u50508 \u47160 \u44256 , \u48372 \u54840 \u51088 \u45716  \u51456 \u54840 \u51032  \u54036 \u44284  \u50612 \u44648 \u50640  \u47693 \u51060  \u51080 \u45716  \u44163 \u51012  \u54869 \u51064 \u54620  \u46244  \u54617 \u44368 \u50640  \u49888 \u44256 \u54664 \u45796 .\
\uc0\u54617 \u44368  \u51204 \u45812 \u44592 \u44396 \u45716  \u45796 \u47480  1\u54617 \u45380  \u54617 \u49373 \u46308 \u51032  \u51652 \u49696 , \u47693  \u49324 \u51652 , \u48372 \u44148 \u49892  \u44592 \u47197 \u51012  \u54869 \u51064 \u54664 \u44256 , \u49324 \u44148 \u51012  \u54617 \u44368 \u54253 \u47141 \u45824 \u52293 \u49900 \u51032 \u50948 \u50896 \u54924 \u47196  \u45336 \u44592 \u44592 \u47196  \u54664 \u45796 . \u54788 \u51116  \u51456 \u54840 \u50752  \u48372 \u54840 \u51088 \u45716  \u49900 \u51032 \u50948 \u50896 \u54924  \u52636 \u49437  \u53685 \u48372 \u47484  \u48155 \u51008  \u49345 \u53468 \u45796 . \u51060  \u49324 \u47168 \u45716  \u45800 \u49692 \u54620  \u50868 \u46041 \u48512  \u54984 \u47144  \u51648 \u46020 \u44032  \u50500 \u45768 \u46972  \u50948 \u44228 \u44288 \u44228  \u49549 \u50640 \u49436  \u48152 \u48373 \u46108  \u49888 \u52404 \u54253 \u47141 \u44284  \u44053 \u50836 \u47196  \u48380  \u49688  \u51080 \u45796 .\
