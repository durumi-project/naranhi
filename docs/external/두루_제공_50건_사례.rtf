\uc0\u51473 \u54617 \u44368  3\u54617 \u45380  \u51648 \u50504 \u51008  \u44368 \u45236  \u48169 \u49569 \u48512  \u50500 \u45208 \u50868 \u49436  \u50669 \u54624 \u51012  \u47585 \u50520 \u45796 . \u50612 \u45712  \u45216  \u51216 \u49900  \u48169 \u49569  \u51473  \u50896 \u44256 \u47484  \u51096 \u47803  \u51069 \u44256  \u51104 \u49884  \u50883 \u51020 \u51012  \u53552 \u46888 \u47160 \u45796 . \u48169 \u49569 \u51060  \u45149 \u45212  \u46244  \u47751 \u47751  \u54617 \u49373 \u46308 \u51060  \u44536  \u51109 \u47732 \u51012  \u55092 \u45824 \u54256 \u51004 \u47196  \u45433 \u54868 \u54620  \u50689 \u49345 \u51012  \u44277 \u50976 \u54664 \u45796 . \u52376 \u51020 \u50640 \u45716  \'93\u44480 \u50685 \u45796 \'94\u45716  \u48152 \u51025 \u46020  \u51080 \u50632 \u51648 \u47564 , \u44263  \u50689 \u49345 \u50640  \u51088 \u47561 \u51060  \u48537 \u44592  \u49884 \u51089 \u54664 \u45796 .\
\uc0\u45572 \u44400 \u44032 \u45716  \u51648 \u50504 \u51060  \u47568 \u51012  \u45908 \u46316 \u45716  \u48512 \u48516 \u47564  \u51096 \u46972  \'93\u48169 \u49569 \u49324 \u44256  \u47112 \u51204 \u46300 \'94\u46972 \u45716  \u51228 \u47785 \u51004 \u47196  \u50732 \u47160 \u44256 , \u45796 \u47480  \u54617 \u49373 \u46308 \u51008  \u49772 \u45716  \u49884 \u44036 \u47560 \u45796  \u51648 \u50504 \u51060  \u51648 \u45208 \u44032 \u47732  \u48169 \u49569  \u47704 \u53944 \u47484  \u46384 \u46972  \u54664 \u45796 . \u51648 \u50504 \u51008  \u48169 \u49569 \u48512  \u54876 \u46041 \u51012  \u44536 \u47564 \u46160 \u44256  \u49910 \u45796 \u44256  \u54664 \u44256 , \u48156 \u54364 \u45208  \u45229 \u46021 \u51060  \u51080 \u45716  \u49688 \u50629 \u46020  \u54588 \u54616 \u47140  \u54664 \u45796 .\
