\f1\b0 \
\uc0\u52488 \u46321 \u54617 \u44368  6\u54617 \u45380  \u47532 \u45208 \u45716  \u50612 \u47672 \u45768 \u44032  \u50808 \u44397  \u52636 \u49888 \u51060 \u45796 . \u47532 \u45208 \u45716  \u54620 \u44397 \u50612 \u47484  \u51096 \u54616 \u51648 \u47564  \u53945 \u51221  \u45800 \u50612 \u47484  \u48156 \u51020 \u54624  \u46412  \u50613 \u50577 \u51060  \u51312 \u44552  \u45804 \u46992 \u45796 . \u47751 \u47751  \u54617 \u49373 \u46308 \u51008  \u47532 \u45208 \u44032  \u48156 \u54364 \u54624  \u46412 \u47560 \u45796  \u48156 \u51020 \u51012  \u46384 \u46972  \u54664 \u44256 , \'93\u45320 \u55148  \u45208 \u46972 \u47196  \u46028 \u50500 \u44032 \u46972 \'94\u45716  \u47568 \u44620 \u51648  \u54664 \u45796 .\
\uc0\u47532 \u45208 \u45716  \u52376 \u51020 \u50640 \u45716  \u52280 \u50520 \u51648 \u47564 , \u49324 \u54924  \u49884 \u44036 \u50640  \u44032 \u51313  \u49548 \u44060  \u54876 \u46041 \u51012  \u54620  \u46244  \u44340 \u47213 \u55192 \u51060  \u49900 \u54644 \u51276 \u45796 . \u52828 \u44396 \u46308 \u51008  \u47532 \u45208 \u51032  \u46020 \u49884 \u46973 \u51012  \u48372 \u44256  \'93\u45252 \u49352 \u45212 \u45796 \'94\u44256  \u54664 \u44256 , \u47532 \u45208 \u44032  \u47784 \u46176 \u54876 \u46041 \u50640  \u52280 \u50668 \u54616 \u47140  \u54616 \u47732  \'93\u45320 \u45716  \u47568  \u51060 \u49345 \u54616 \u44172  \u54616 \u45768 \u44620  \u48156 \u54364 \u54616 \u51648  \u47560 \'94\u46972 \u44256  \u54664 \u45796 . \u47532 \u45208 \u45716  \u51216 \u51216  \u47568 \u51012  \u54616 \u51648  \u50506 \u44172  \u46104 \u50632 \u44256 , \u48156 \u54364 \u44032  \u51080 \u45716  \u45216 \u50640 \u45716  \u44208 \u49437 \u54616 \u44256  \u49910 \u45796 \u44256  \u54664 \u45796 .\
\uc0\u45812 \u51076 \u44368 \u49324 \u44032  \u47532 \u45208 \u51032  \u48320 \u54868 \u47484  \u48372 \u44256  \u49345 \u45812 \u51012  \u51652 \u54665 \u54664 \u44256 , \u47532 \u45208 \u45716  \u44536 \u46041 \u50504  \u51080 \u50632 \u45912  \u51068 \u51012  \u53560 \u50612 \u45459 \u50520 \u45796 . \u54788 \u51116  \u54617 \u44368  \u51204 \u45812 \u44592 \u44396 \u45716  \u51452 \u48320  \u54617 \u49373  \u51652 \u49696 \u44284  \u49688 \u50629  \u51473  \u48156 \u50616 , \u47784 \u46176 \u54876 \u46041  \u48176 \u51228  \u51221 \u54889 \u51012  \u51312 \u49324 \u54616 \u44256  \u51080 \u45796 . \u51060  \u49324 \u44148 \u51008  \u45800 \u49692  \u45440 \u47548 \u51060  \u50500 \u45768 \u46972  \u44032 \u51313  \u48176 \u44221 \u44284  \u47928 \u54868 \u51201  \u52264 \u51060 \u47484  \u51060 \u50976 \u47196  \u54620  \u52264 \u48324 \u51201  \u44340 \u47213 \u55192 \u51060 \u45796 .\
