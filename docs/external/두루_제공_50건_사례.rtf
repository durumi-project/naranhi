\uc0\u44256 \u46321 \u54617 \u44368  2\u54617 \u45380  \u49436 \u51456 \u51008  \u54617 \u49373 \u54924  \u54861 \u48372 \u48512 \u50640  \u46308 \u50612 \u44052 \u45796 . \u52376 \u51020 \u50640 \u45716  \u49440 \u48176 \u46308 \u51060  \u52828 \u51208 \u54616 \u44172  \u50629 \u47924 \u47484  \u50508 \u47140 \u51452 \u45716  \u46319 \u54664 \u45796 . \u54616 \u51648 \u47564  \u49436 \u51456 \u51060  \u54924 \u51032 \u50640 \u49436  \u45796 \u47480  \u51032 \u44204 \u51012  \u45236 \u51088  \u48516 \u50948 \u44592 \u44032  \u48148 \u45068 \u50632 \u45796 . \u48512 \u51109  \u54617 \u49373 \u51008  \'93\u49888 \u51077 \u51060  \u47960  \u50504 \u45796 \u44256  \u44536 \u47084 \u45264 \'94\u47728  \u49436 \u51456 \u51032  \u51032 \u44204 \u51012  \u47924 \u49884 \u54664 \u45796 .\
\uc0\u51060 \u54980  \u49436 \u51456 \u51008  \u54617 \u49373 \u54924  \u45800 \u52404  \u52292 \u54021 \u48169 \u50640 \u49436  \u44277 \u51648 \u47484  \u45734 \u44172  \u48155 \u44144 \u45208 , \u54924 \u51032  \u49884 \u44036  \u48320 \u44221 \u51012  \u54844 \u51088  \u51204 \u45804 \u48155 \u51648  \u47803 \u54616 \u45716  \u51068 \u51060  \u48152 \u48373 \u46096 \u45796 . \u54665 \u49324  \u51456 \u48708  \u46412 \u46020  \u45796 \u47480  \u54617 \u49373 \u46308 \u51008  \u50669 \u54624 \u51012  \u45208 \u45620 \u51648 \u47564  \u49436 \u51456 \u50640 \u44172 \u45716  \u51105 \u51068 \u47564  \u47585 \u44220 \u45796 . \u49436 \u51456 \u51060  \u54637 \u51032 \u54616 \u51088  \u48512 \u51109 \u51008  \'93\u45348 \u44032  \u48516 \u50948 \u44592 \u47484  \u47803  \u47582 \u52656 \u49436  \u44536 \u47111 \u45796 \'94\u44256  \u54664 \u45796 . \u45208 \u51473 \u50640 \u45716  \u54861 \u48372 \u47932  \u51228 \u51089  \u44208 \u44284 \u47932 \u50640 \u49436  \u49436 \u51456 \u51032  \u51060 \u47492 \u47564  \u48736 \u51276 \u45796 .\
\uc0\u49436 \u51456 \u51032  \u48372 \u54840 \u51088 \u45716  \u51060 \u44163 \u51060  \u45800 \u49692 \u54620  \u46041 \u50500 \u47532  \u44040 \u46321 \u51060  \u50500 \u45768 \u46972  \u44428 \u54620 \u51012  \u44032 \u51652  \u54617 \u49373 \u46308 \u51060  \u51312 \u51649 \u51201 \u51004 \u47196  \u48176 \u51228 \u54620  \u44163 \u51060 \u46972 \u44256  \u48372 \u44256  \u49888 \u44256 \u54664 \u45796 . \u51204 \u45812 \u44592 \u44396  \u51312 \u49324 \u44032  \u45149 \u45228 \u44256 , \u54788 \u51116  \u49900 \u51032 \u50948 \u50896 \u54924  \u52636 \u49437  \u53685 \u48372 \u44032  \u50728  \u49345 \u53468 \u45796 . \u51060  \u49324 \u47168 \u45716  \u54617 \u49373 \u54924 \u45208  \u46041 \u50500 \u47532 \u52376 \u47100  \u51088 \u52824 \u51312 \u51649  \u50504 \u50640 \u49436 \u46020  \u44428 \u47141 \u44288 \u44228 \u47484  \u51060 \u50857 \u54620  \u46384 \u46028 \u47548 \u51060  \u48156 \u49373 \u54624  \u49688  \u51080 \u45796 \u45716  \u51216 \u51012  \u48372 \u50668 \u51456 \u45796 .\
