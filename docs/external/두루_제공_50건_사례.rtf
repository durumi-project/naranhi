\f1\b0 \
\uc0\u51473 \u54617 \u44368  2\u54617 \u45380  \u50696 \u47536 \u51008  \u50612 \u45712  \u45216  \u52828 \u44396 \u50640 \u44172 \u49436  \'93\u54868 \u51109 \u49892 \u50640  \u45348  \u51060 \u47492 \u51060  \u51201 \u54784  \u51080 \u45796 \'94\u45716  \u47568 \u51012  \u46308 \u50632 \u45796 . \u50668 \u51088  \u54868 \u51109 \u49892  \u52856  \u50504 \u51901 \u50640 \u45716  \u50696 \u47536 \u51032  \u51060 \u47492 \u44284  \u54632 \u44760  \u49324 \u49892 \u51060  \u50500 \u45772  \u45236 \u50857 \u51032  \u47784 \u50837 \u51201 \u51064  \u47928 \u51109 \u51060  \u51201 \u54784  \u51080 \u50632 \u45796 . \u50696 \u47536 \u51008  \u52649 \u44201 \u51012  \u48155 \u44256  \u48148 \u47196  \u45812 \u51076 \u50640 \u44172  \u50508 \u47160 \u45796 .\
\uc0\u52376 \u51020 \u50640 \u45716  \u45572 \u44032  \u50420  \u44163 \u51064 \u51648  \u50508  \u49688  \u50630 \u50632 \u45796 . \u54616 \u51648 \u47564  \u47728 \u52832  \u46244  \u44057 \u51008  \u47928 \u44396 \u44032  \u52293 \u49345  \u50948  \u45209 \u49436 \u50752  \u51061 \u47749 \u44172 \u49884 \u54032  \u44544 \u47196 \u46020  \u51060 \u50612 \u51276 \u45796 . \u50696 \u47536 \u51060  \u48373 \u46020 \u47484  \u51648 \u45208 \u44032 \u47732  \u47751 \u47751  \u54617 \u49373 \u46308 \u51060  \u50883 \u44144 \u45208  \u49688 \u44400 \u44144 \u47160 \u44256 , \u50696 \u47536 \u51008  \u51088 \u49888 \u51060  \u44228 \u49549  \u51648 \u53020 \u48372 \u51060 \u44256  \u54217 \u44032 \u48155 \u45716  \u45712 \u45196 \u51012  \u48155 \u50520 \u45796 . \u50696 \u47536 \u51008  \u54617 \u44368 \u50640  \u44032 \u44592  \u49899 \u45796 \u44256  \u47568 \u54664 \u44256 , \u48372 \u54840 \u51088 \u45716  \u51221 \u49885  \u51312 \u49324 \u47484  \u50836 \u44396 \u54664 \u45796 .\
\uc0\u54617 \u44368 \u45716  \u54868 \u51109 \u49892  \u51452 \u48320  CCTV \u46041 \u49440 , \u45209 \u49436  \u48156 \u44204  \u49884 \u44036 , \u51061 \u47749 \u44172 \u49884 \u54032  \u44544  \u51089 \u49457  \u49884 \u44033 , \u44288 \u47144 \u54617 \u49373 \u46308 \u51032  \u51652 \u49696 \u51012  \u51312 \u49324 \u54664 \u45796 . \u51204 \u45812 \u44592 \u44396  \u51312 \u49324 \u44032  \u45149 \u45212  \u46244  \u49324 \u44148 \u51008  \u49900 \u51032 \u50948 \u50896 \u54924 \u47196  \u45336 \u50612 \u44052 \u44256 , \u54788 \u51116  \u50696 \u47536 \u44284  \u48372 \u54840 \u51088 \u45716  \u52636 \u49437  \u53685 \u48372 \u47484  \u48155 \u51008  \u49345 \u53468 \u45796 . \u51060  \u49324 \u44148 \u51008  \u45209 \u49436 \u46972 \u45716  \u50724 \u54532 \u46972 \u51064  \u54665 \u50948 \u50752  \u50728 \u46972 \u51064  \u44172 \u49884 \u44544 , \u51452 \u48320  \u54617 \u49373 \u46308 \u51032  \u49548 \u47928  \u54869 \u49328 \u51060  \u44208 \u54633 \u46108  \u49324 \u47168 \u45796 .\
