\uc0\u51473 \u54617 \u44368  1\u54617 \u45380  \u54616 \u51456 \u51008  \u52404 \u50977  \u49884 \u44036 \u51060  \u45149 \u45212  \u46244  \u51088 \u49888 \u51032  \u44368 \u48373  \u49492 \u52768 \u50640  \u45209 \u49436 \u44032  \u46104 \u50612  \u51080 \u45716  \u44163 \u51012  \u48156 \u44204 \u54664 \u45796 . \u52376 \u51020 \u50640 \u45716  \u50864 \u50672 \u51060 \u46972 \u44256  \u49373 \u44033 \u54664 \u51648 \u47564 , \u47728 \u52832  \u46244  \u49892 \u45236 \u54868  \u50504 \u50640  \u47932 \u51060  \u46308 \u50612 \u44032  \u51080 \u50632 \u44256 , \u52293 \u44032 \u48169  \u51648 \u54140 \u44032  \u44256 \u51109  \u45208  \u51080 \u50632 \u45796 . \u54616 \u51456 \u51008  \u45572 \u44032  \u54664 \u45716 \u51648  \u50508  \u49688  \u50630 \u50632 \u51648 \u47564 , \u53945 \u51221  \u54617 \u49373 \u46308 \u51060  \u54616 \u51456 \u51032  \u48152 \u51025 \u51012  \u48372 \u47728  \u50883 \u45716  \u44163 \u51012  \u48372 \u50520 \u45796 .\
\uc0\u54616 \u51456 \u51008  \u45812 \u51076 \u50640 \u44172  \u47568 \u54664 \u44256 , \u54617 \u44368 \u45716  CCTV\u50752  \u51452 \u48320  \u54617 \u49373  \u51652 \u49696 \u51012  \u54869 \u51064 \u54664 \u45796 . \u51312 \u49324  \u44208 \u44284  \u47751 \u47751  \u54617 \u49373 \u46308 \u51060  \u54616 \u51456 \u51032  \u47932 \u44148 \u51012  \u49704 \u44592 \u44144 \u45208  \u55036 \u49552 \u54620  \u51221 \u54889 \u51060  \u54869 \u51064 \u46096 \u45796 . \u49900 \u51032 \u50948 \u50896 \u54924 \u45716  \u44032 \u54644 \u54617 \u49373 \u46308 \u50640 \u44172  \u49436 \u47732 \u49324 \u44284 , \u54588 \u54644  \u47932 \u54408  \u48320 \u49345 , \u53945 \u48324 \u44368 \u50977  \u51312 \u52824 \u47484  \u44208 \u51221 \u54664 \u45796 .\
\uc0\u44536 \u47084 \u45208  \u44032 \u54644 \u54617 \u49373  \u52769 \u51008  \'93\u51109 \u45212 \u51060 \u50632 \u44256  \u49892 \u51228  \u49552 \u54644 \u44032  \u53356 \u51648  \u50506 \u45796 \'94\u47728  \u52376 \u48516 \u51060  \u44284 \u54616 \u45796 \u44256  \u54665 \u51221 \u49900 \u54032 \u51012  \u52397 \u44396 \u54664 \u45796 . \u54788 \u51116  \u54616 \u51456  \u52769 \u51008  \u48520 \u48373  \u51208 \u52264 \u50640  \u45824 \u51025 \u54616 \u44592  \u50948 \u54644  \u55036 \u49552 \u46108  \u47932 \u44148  \u49324 \u51652 , \u49688 \u47532 \u48708  \u50689 \u49688 \u51613 , \u48152 \u48373  \u48156 \u49373  \u45216 \u51676 \u47484  \u51221 \u47532 \u54616 \u44256  \u51080 \u45796 . \u51060  \u49324 \u47168 \u45716  \u47932 \u44148  \u55036 \u49552 \u51060  \u45800 \u49692  \u51109 \u45212 \u51060  \u50500 \u45768 \u46972  \u48152 \u48373 \u51201  \u44340 \u47213 \u55192 \u51032  \u49688 \u45800 \u51060  \u46112  \u49688  \u51080 \u51020 \u51012  \u48372 \u50668 \u51456 \u45796 .\
