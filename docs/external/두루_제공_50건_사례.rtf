\uc0\u51473 \u54617 \u44368  2\u54617 \u45380  \u51116 \u50896 \u51008  \u49688 \u54617  \u49884 \u54744 \u51012  \u47581 \u52828  \u46244  \u51312 \u50857 \u55176  \u51648 \u45236 \u44256  \u49910 \u50632 \u45796 . \u44536 \u47088 \u45936  \u44057 \u51008  \u48152  \u54617 \u49373  \u54620  \u47749 \u51060  \u50864 \u50672 \u55176  \u51116 \u50896 \u51032  \u51216 \u49688 \u47484  \u48372 \u44172  \u46104 \u50632 \u44256 , \u49772 \u45716  \u49884 \u44036 \u50640  \'93\u51116 \u50896 \u51060  \u51060 \u48264 \u50640  \u47751  \u51216  \u47582 \u50520 \u45716 \u51648  \u50500 \u45264 ?\'94\u47728  \u45796 \u47480  \u52828 \u44396 \u46308 \u50640 \u44172  \u47568 \u54664 \u45796 . \u52376 \u51020 \u50640 \u45716  \u47751  \u47749 \u47564  \u50508 \u45912  \u51216 \u49688 \u44032  \u54616 \u47336  \u47564 \u50640  \u48152  \u51204 \u52404 \u50640  \u54140 \u51276 \u45796 .\
\uc0\u54617 \u49373 \u46308 \u51008  \u51116 \u50896 \u50640 \u44172  \'93\u44536  \u51216 \u49688 \u47196  \u44256 \u46321 \u54617 \u44368  \u44032 \u44192 \u45264 \'94, \'93\u44277 \u48512 \u54616 \u45716  \u52377 \u54616 \u45908 \u45768  \u50883 \u44592 \u45796 \'94\u44256  \u47568 \u54664 \u45796 . \u45800 \u52404  \u52292 \u54021 \u48169 \u50640 \u45716  \u51116 \u50896 \u51032  \u51060 \u47492 \u44284  \u51216 \u49688 \u47484  \u50516 \u49884 \u54616 \u45716  \u44544 \u51060  \u50732 \u46972 \u50772 \u45796 . \u51116 \u50896 \u51008  \u49457 \u51201  \u51088 \u52404 \u48372 \u45796  \u51088 \u49888 \u51032  \u51216 \u49688 \u44032  \u50883 \u51020 \u44144 \u47532 \u52376 \u47100  \u54140 \u51276 \u45796 \u45716  \u49324 \u49892 \u50640  \u53360  \u49688 \u52824 \u49900 \u51012  \u45712 \u44808 \u45796 .\
\uc0\u48372 \u54840 \u51088 \u44032  \u54617 \u44368 \u50640  \u49888 \u44256 \u54664 \u44256 , \u51204 \u45812 \u44592 \u44396 \u45716  \u44288 \u47144 \u54617 \u49373  \u51652 \u49696 \u44284  \u52292 \u54021 \u48169  \u47700 \u49884 \u51648 \u47484  \u54869 \u51064 \u54664 \u45796 . \u54788 \u51116  \u54617 \u44368 \u45716  \u51088 \u52404 \u54644 \u44208  \u44032 \u45733 \u49457 \u51012  \u44160 \u53664  \u51473 \u51060 \u45796 . \u45796 \u47564  \u54588 \u54644 \u54617 \u49373 \u51060  \u49900 \u47532 \u51201  \u44256 \u53685 \u51012  \u54840 \u49548 \u54616 \u44256 , \u49457 \u51201 \u51060 \u46972 \u45716  \u48124 \u44048 \u54620  \u51221 \u48372 \u47484  \u51060 \u50857 \u54644  \u48152 \u48373 \u51201 \u51004 \u47196  \u51312 \u47217 \u54664 \u45796 \u45716  \u51216 \u50640 \u49436  \u45800 \u49692  \u49324 \u44284 \u47196  \u45149 \u45244  \u49688  \u51080 \u51012 \u51648  \u45436 \u46976 \u51060  \u51080 \u45796 .\
