\uc0\u49548 \u50980 \u51060  \'93\u45208 \u46020  \u44057 \u51060  \u52237 \u44256  \u49910 \u45796 \'94\u44256  \u47568 \u54616 \u47732  \u52828 \u44396 \u46308 \u51008  \'93\u45796 \u51020 \u50640  \u52237 \u51088 \'94\u44256  \u54664 \u51648 \u47564 , \u45796 \u51020 \u50640 \u46020  \u49548 \u50980 \u51012  \u48512 \u47476 \u51648  \u50506 \u50520 \u45796 . \u50612 \u45712  \u45216  \u49548 \u50980 \u51008  \u52828 \u44396 \u46308 \u51060  \u51088 \u49888 \u51060  \u54868 \u51109 \u49892 \u50640  \u44036  \u49324 \u51060  \u51068 \u48512 \u47084  \u45800 \u52404 \u49324 \u51652 \u51012  \u52237 \u50632 \u45796 \u45716  \u49324 \u49892 \u51012  \u50508 \u44172  \u46104 \u50632 \u45796 . \u49548 \u50980 \u51008  \u51088 \u49888 \u51060  \u50630 \u45716  \u49324 \u51652 \u46308 \u51060  \u44228 \u49549  \u50732 \u46972 \u50724 \u45716  \u44163 \u51012  \u48372 \u47728  \u49900 \u54620  \u49548 \u50808 \u44048 \u51012  \u45712 \u44808 \u45796 .\
