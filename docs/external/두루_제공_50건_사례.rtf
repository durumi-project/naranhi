\uc0\u44256 \u46321 \u54617 \u44368  1\u54617 \u45380  \u51648 \u48124 \u51008  \u49688 \u54665 \u54217 \u44032  \u51312 \u48324 \u44284 \u51228 \u50640 \u49436  \u51312 \u51109 \u51012  \u47585 \u50520 \u45796 . \u44057 \u51008  \u51312  \u54617 \u49373  \u54620  \u47749 \u51008  \u51648 \u48124 \u51060  \u51312 \u51109 \u51060  \u46108  \u44163 \u51012  \u47803 \u47560 \u46405 \u54644 \u54616 \u47728  \'93\u51172 \u44032  \u51312 \u51109 \u51060 \u47732  \u47581 \u54664 \u45796 \'94\u44256  \u47568 \u54664 \u45796 . \u51060 \u54980  \u51312 \u48324  \u52292 \u54021 \u48169 \u50640 \u49436  \u51648 \u48124 \u51032  \u51032 \u44204 \u51012  \u47924 \u49884 \u54664 \u44256 , \u51648 \u48124 \u51060  \u51221 \u47532 \u54620  \u48156 \u54364  \u51088 \u47308 \u47484  \u48708 \u44844 \u45716  \u44544 \u51012  \u50732 \u47160 \u45796 .\
\uc0\u47928 \u51228 \u45716  \u44277 \u50976 \u47928 \u49436 \u50640 \u49436  \u48156 \u49373 \u54664 \u45796 . \u51648 \u48124 \u51060  \u48164 \u45734 \u44172  \u51089 \u49457 \u54620  \u48156 \u54364  \u51088 \u47308  \u51068 \u48512 \u44032  \u45796 \u51020  \u45216  \u49325 \u51228 \u46104 \u50612  \u51080 \u50632 \u45796 . \u44032 \u54644 \u54617 \u49373 \u51008  \'93\u49892 \u49688 \u47196  \u51648 \u50868  \u44163 \'94\u51060 \u46972 \u44256  \u54664 \u51648 \u47564 , \u47928 \u49436  \u49688 \u51221  \u44592 \u47197 \u50640 \u45716  \u44057 \u51008  \u44228 \u51221 \u51060  \u50668 \u47084  \u52264 \u47168  \u51217 \u49549 \u54644  \u51648 \u48124 \u51032  \u51089 \u49457  \u48512 \u48516 \u51012  \u49325 \u51228 \u54620  \u55124 \u51201 \u51060  \u45224 \u50500  \u51080 \u50632 \u45796 . \u48156 \u54364  \u45817 \u51068 \u50640 \u45716  \u51088 \u47308 \u44032  \u45572 \u46973 \u46104 \u50612  \u51648 \u48124 \u51060  \u53360  \u48520 \u51060 \u51061 \u51012  \u48155 \u50520 \u44256 , \u51312 \u50896 \u46308 \u51008  \u51648 \u48124 \u50640 \u44172  \u52293 \u51076 \u51012  \u46028 \u47160 \u45796 .\
\uc0\u49900 \u51032 \u50948 \u50896 \u54924 \u45716  \u44032 \u54644 \u54617 \u49373 \u50640 \u44172  \u49436 \u47732 \u49324 \u44284 , \u51217 \u52489 \u44552 \u51648 , \u53945 \u48324 \u44368 \u50977 , \u54617 \u44368 \u48393 \u49324  \u51312 \u52824 \u47484  \u44208 \u51221 \u54664 \u45796 . \u44536 \u47084 \u45208  \u44032 \u54644 \u54617 \u49373  \u52769  \u48372 \u54840 \u51088 \u45716  \'93\u51312 \u48324 \u44284 \u51228  \u51473  \u49373 \u44596  \u44040 \u46321 \u51068  \u49104  \u54617 \u44368 \u54253 \u47141 \u51060  \u50500 \u45768 \u45796 \'94\u46972 \u47728  \u54665 \u51221 \u49900 \u54032 \u51012  \u52397 \u44396 \u54664 \u45796 . \u54788 \u51116  \u51648 \u48124  \u52769 \u51008  \u48520 \u48373  \u51208 \u52264  \u44284 \u51221 \u50640 \u49436  \u54588 \u54644 \u44032  \u52629 \u49548 \u46112 \u44620  \u48400  \u44145 \u51221 \u54616 \u44256  \u51080 \u51004 \u47728 , \u44277 \u50976 \u47928 \u49436  \u47196 \u44536 \u50752  \u52292 \u54021 \u48169  \u44592 \u47197 \u51012  \u45796 \u49884  \u51221 \u47532 \u54616 \u44256  \u51080 \u45796 .\
