\f1\b0 \
\uc0\u44256 \u46321 \u54617 \u44368  1\u54617 \u45380  \u46020 \u54616 \u45716  \u48156 \u54364 \u47484  \u50612 \u47140 \u50892 \u54616 \u45716  \u54617 \u49373 \u51060 \u50632 \u45796 . \u44057 \u51008  \u48152  \u54617 \u49373 \u46308 \u51008  \u46020 \u54616 \u44032  \u44596 \u51109 \u54616 \u47732  \u47568 \u51012  \u45908 \u46316 \u45716 \u45796 \u45716  \u44163 \u51012  \u50508 \u44256  \u51080 \u50632 \u45796 . \u50612 \u45712  \u45216  \u49324 \u54924  \u49688 \u54665 \u54217 \u44032  \u48156 \u54364 \u50640 \u49436  \u47751 \u47751  \u54617 \u49373 \u46308 \u51060  \u46020 \u54616 \u50640 \u44172  \u51068 \u48512 \u47084  \u50612 \u47140 \u50868  \u51656 \u47928 \u51012  \u44228 \u49549  \u45912 \u51276 \u45796 .\
\uc0\u51656 \u47928  \u51088 \u52404 \u45716  \u44169 \u51004 \u47196  \u48372 \u47732  \u49688 \u50629  \u45236 \u50857 \u44284  \u44288 \u47144 \u51060  \u51080 \u50632 \u45796 . \u54616 \u51648 \u47564  \u54617 \u49373 \u46308 \u51008  \u46020 \u54616 \u44032  \u45824 \u45813 \u54616 \u51648  \u47803 \u54624  \u46412 \u47560 \u45796  \u50883 \u50632 \u44256 , \'93\u44536 \u44163 \u46020  \u47784 \u47476 \u47732 \u49436  \u48156 \u54364 \u54664 \u45264 \'94\u44256  \u47568 \u54664 \u45796 . \u48156 \u54364 \u44032  \u45149 \u45212  \u46244 \u50640 \u45716  \u45800 \u52404  \u52292 \u54021 \u48169 \u50640  \'93\u50724 \u45720  \u48156 \u54364  \u47112 \u51204 \u46300 \'94\u46972 \u45716  \u44544 \u44284  \u54632 \u44760  \u46020 \u54616 \u44032  \u45817 \u54889 \u54620  \u54364 \u51221 \u51012  \u52897 \u52376 \u54620  \u49324 \u51652 \u51060  \u50732 \u46972 \u50772 \u45796 .\
\uc0\u46020 \u54616 \u45716  \u48156 \u54364  \u51060 \u54980  \u49688 \u50629  \u52280 \u50668 \u47484  \u54588 \u54664 \u44256 , \u49345 \u45812 \u44368 \u49324 \u50640 \u44172  \'93\u45796 \u51020  \u48156 \u54364 \u44032  \u47924 \u49453 \u45796 \'94\u44256  \u47568 \u54664 \u45796 . \u48372 \u54840 \u51088 \u44032  \u49888 \u44256 \u54664 \u44256 , \u51204 \u45812 \u44592 \u44396  \u51312 \u49324  \u44208 \u44284  \u51068 \u48512  \u54617 \u49373 \u46308 \u51060  \u48156 \u54364  \u51204 \u48512 \u53552  \'93\u46020 \u54616  \u45817 \u54889 \u54616 \u44172  \u47564 \u46308 \u51088 \'94\u44256  \u51060 \u50556 \u44592 \u54620  \u51221 \u54889 \u51060  \u54869 \u51064 \u46096 \u45796 . \u54788 \u51116  \u49900 \u51032 \u50948 \u50896 \u54924  \u52636 \u49437  \u53685 \u48372 \u44032  \u50728  \u49345 \u53468 \u45796 . \u51060  \u49324 \u47168 \u45716  \u51656 \u47928 \u51060 \u46972 \u45716  \u54805 \u49885 \u51012  \u48716 \u47536  \u44277 \u44060 \u51201  \u47581 \u49888  \u51452 \u44592 \u50752  \u54617 \u50629 \u48169 \u54644 \u50640  \u54644 \u45817 \u54624  \u49688  \u51080 \u45796 .\
