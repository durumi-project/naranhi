\f1\b0 \
\uc0\u44256 \u46321 \u54617 \u44368  1\u54617 \u45380  \u45812 \u51076 \u44368 \u49324 \u45716  \u54617 \u44553  \u48516 \u50948 \u44592 \u47484  \u51339 \u44172  \u47564 \u46308 \u44592  \u50948 \u54644  \u51061 \u47749  \u52845 \u52268 \u54632 \u51012  \u50868 \u50689 \u54664 \u45796 . \u54617 \u49373 \u46308 \u51008  \u52828 \u44396 \u50640 \u44172  \u44256 \u47560 \u50868  \u47568 \u51012  \u50024 \u49436  \u45347 \u45716  \u48169 \u49885 \u51060 \u50632 \u45796 . \u44536 \u47088 \u45936  \u50612 \u45712  \u49692 \u44036 \u48512 \u53552  \u53945 \u51221  \u54617 \u49373 \u51064  \u49688 \u54788 \u51012  \u51312 \u47217 \u54616 \u45716  \u51901 \u51648 \u44032  \u48152 \u48373 \u51201 \u51004 \u47196  \u46308 \u50612 \u50724 \u44592  \u49884 \u51089 \u54664 \u45796 .\
\uc0\u52376 \u51020 \u50640 \u45716  \'93\u49688 \u54788 \u51060 \u45716  \u51312 \u50857 \u54644 \u49436  \u51316 \u51116 \u44048 \u51060  \u50630 \u45796 \'94\u45716  \u51221 \u46020 \u50688 \u51648 \u47564 , \u45208 \u51473 \u50640 \u45716  \u50808 \u47784 \u50752  \u49457 \u44201 \u51012  \u48708 \u54616 \u54616 \u45716  \u47928 \u51109 \u51060  \u51201 \u54804 \u45796 . \u45812 \u51076 \u51008  \u51109 \u45212 \u51060 \u46972 \u44256  \u49373 \u44033 \u54616 \u44256  \u54620 \u46160  \u48264  \u51452 \u51032 \u47484  \u51452 \u50632 \u51648 \u47564 , \u51901 \u51648 \u45716  \u44228 \u49549 \u46096 \u45796 . \u49688 \u54788 \u51008  \u51088 \u49888 \u51060  \u48152  \u51204 \u52404  \u50526 \u50640 \u49436  \u44277 \u44060 \u51201 \u51004 \u47196  \u51312 \u47217 \u45817 \u54616 \u45716  \u45712 \u45196 \u51012  \u48155 \u50520 \u44256 , \u54617 \u44368  \u49345 \u45812 \u51012  \u48155 \u44592  \u49884 \u51089 \u54664 \u45796 .\
\uc0\u49900 \u51032  \u51208 \u52264 \u45716  \u51652 \u54665 \u46104 \u50632 \u51648 \u47564 , \u49688 \u54788 \u51032  \u48372 \u54840 \u51088 \u45716  \u54617 \u44368 \u44032  \u52488 \u44592 \u50640  \u52649 \u48516 \u55176  \u47561 \u51648  \u50506 \u50520 \u45796 \u44256  \u45712 \u45180 \u44256  \u51080 \u45796 . \u54788 \u51116 \u45716  \u54617 \u44368 \u54253 \u47141  \u51208 \u52264 \u50752  \u48324 \u46020 \u47196  \u51221 \u49888 \u51201  \u49552 \u54644 \u50640  \u45824 \u54620  \u48124 \u49324 \u49345  \u45824 \u51025 \u51012  \u44160 \u53664 \u54616 \u44256  \u51080 \u51004 \u47728 , \u51068 \u48512  \u51901 \u51648  \u45236 \u50857 \u51060  \u49900 \u44033 \u54644  \u47784 \u50837  \u47928 \u51228 \u46020  \u54632 \u44760  \u49332 \u54196 \u48372 \u44256  \u51080 \u45796 . \u51060  \u49324 \u47168 \u45716  \u51061 \u47749 \u49457 \u51012  \u51060 \u50857 \u54620  \u48152 \u48373 \u51201  \u51312 \u47217 \u44284  \u54617 \u44368 \u51032  \u52488 \u44592  \u45824 \u51025  \u47928 \u51228 \u44032  \u54632 \u44760  \u50621 \u55180  \u49324 \u44148 \u51060 \u45796 .\
