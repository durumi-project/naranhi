\f1\b0 \
\uc0\u51473 \u54617 \u44368  2\u54617 \u45380  \u51648 \u54840 \u45716  \u50724 \u47000 \u46108  \u50868 \u46041 \u54868 \u47484  \u49888 \u44256  \u45796 \u45396 \u45796 . \u50612 \u45712  \u45216  \u44057 \u51008  \u48152  \u54617 \u49373 \u51060  \'93\u45320  \u49888 \u48156  \u50616 \u51228  \u49328  \u44144 \u45264 \'94\u47728  \u50883 \u50632 \u44256 , \u45796 \u47480  \u54617 \u49373 \u46308 \u51060  \u44536  \u47568 \u50640  \u48152 \u51025 \u54616 \u47732 \u49436  \u51648 \u54840 \u51032  \u44032 \u51221 \u54805 \u54200 \u51012  \u46160 \u44256  \u45440 \u47532 \u45716  \u48516 \u50948 \u44592 \u44032  \u49373 \u44220 \u45796 . \'93\u44553 \u49885 \u48708  \u51648 \u50896 \u48155 \u45264 \'94, \'93\u46024  \u50630 \u51004 \u47732  \u54617 \u44368  \u50612 \u46523 \u44172  \u45796 \u45768 \u45264 \'94\u45716  \u47568 \u46020  \u45208 \u50772 \u45796 .\
\uc0\u52376 \u51020 \u50640 \u45716  \u47568 \u49104 \u51060 \u50632 \u51648 \u47564 , \u51060 \u54980  \u51648 \u54840 \u51032  \u52404 \u50977 \u48373 \u51060  \u49324 \u46972 \u51648 \u44144 \u45208  \u49892 \u45236 \u54868 \u44032  \u50416 \u47112 \u44592 \u53685  \u50694 \u50640 \u49436  \u48156 \u44204 \u46104 \u45716  \u51068 \u51060  \u49373 \u44220 \u45796 . \u51648 \u54840 \u45716  \u45572 \u44032  \u54664 \u45716 \u51648  \u50508  \u49688  \u50630 \u50632 \u51648 \u47564 , \u53945 \u51221  \u54617 \u49373 \u46308 \u51060  \u51088 \u49888 \u51032  \u48152 \u51025 \u51012  \u48372 \u47728  \u50883 \u45716  \u44163 \u51012  \u48372 \u50520 \u45796 . \u50612 \u45712  \u45216 \u51008  \u52293 \u49345  \u50948 \u50640  \'93\u54980 \u50896  \u44228 \u51340  \u51201 \u50612 \u46972 \'94\u46972 \u45716  \u51901 \u51648 \u44032  \u48537 \u50612  \u51080 \u50632 \u45796 .\
\uc0\u51648 \u54840 \u45716  \u45812 \u51076 \u44368 \u49324 \u50640 \u44172  \u50872 \u47732 \u49436  \u51060  \u49324 \u49892 \u51012  \u47568 \u54664 \u44256 , \u45812 \u51076 \u51008  \u51593 \u49884  \u48372 \u54840 \u51088 \u50640 \u44172  \u50672 \u46973 \u54620  \u46244  \u54617 \u44368 \u54253 \u47141  \u49324 \u50504 \u51004 \u47196  \u51217 \u49688 \u54664 \u45796 . \u54788 \u51116  \u54617 \u44368 \u45716  \u49324 \u44148 \u51012  \u51064 \u51648 \u54616 \u44256  \u49888 \u44256  \u51217 \u49688 \u47484  \u50756 \u47308 \u54620  \u49345 \u53468 \u45796 . \u50500 \u51649  \u51204 \u45812 \u44592 \u44396  \u51312 \u49324 \u44032  \u48376 \u44201 \u51201 \u51004 \u47196  \u51652 \u54665 \u46104 \u51648 \u45716  \u50506 \u50520 \u51648 \u47564 , \u51901 \u51648 , \u47932 \u44148  \u55036 \u49552  \u51221 \u54889 , \u51452 \u48320  \u54617 \u49373  \u51652 \u49696 \u51012  \u54869 \u48372 \u54624  \u54596 \u50836 \u44032  \u51080 \u45796 .\
