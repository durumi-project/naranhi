\f0\b\fs36 \cf2 \strokec2 2. \uc0\u45800 \u53665 \u48169  \u49324 \u51652  \u54633 \u49457 \u50640 \u49436  \u49884 \u51089 \u46108  \u49324 \u51060 \u48260 \u54253 \u47141 \
\pard\pardeftab720\sa240\partightenfactor0

\fs24 \cf2 \uc0\u52852 \u53580 \u44256 \u47532 : \u49324 \u51060 \u48260 \u54253 \u47141 , \u51060 \u48120 \u51648  \u51312 \u47217 , \u47749 \u50696 \u55036 \u49552 \u49457  \u44172 \u49884 \u47932 
\f1\b0 \uc0\u8232 
\f0\b \uc0\u54788 \u51116  \u51208 \u52264  \u45800 \u44228 : \u54617 \u44368  \u51064 \u51648 \'b7\u49888 \u44256  \u51217 \u49688 
\f1\b0 \
\uc0\u44256 \u46321 \u54617 \u44368  1\u54617 \u45380  \u49436 \u50672 \u51008  \u48152  \u45800 \u52404  \u52292 \u54021 \u48169 \u50640 \u49436  \u51656 \u47928 \u51012  \u51088 \u51452  \u54616 \u45716  \u54617 \u49373 \u51060 \u50632 \u45796 . \u50612 \u45712  \u45216  \u44057 \u51008  \u48152  \u54617 \u49373  \u54620  \u47749 \u51060  \u49436 \u50672 \u51032  SNS \u49324 \u51652 \u51012  \u51200 \u51109 \u54644  \u50620 \u44404 \u51012  \u50864 \u49828 \u44893 \u49828 \u47101 \u44172  \u45720 \u47536  \u46244 , \u52828 \u44396 \u46308 \u47564  \u51080 \u45716  \u48708 \u44277 \u44060  \u52292 \u54021 \u48169 \u50640  \u50732 \u47160 \u45796 . \u52376 \u51020 \u50640 \u45716  \u47751  \u47749 \u51060  \u50883 \u44256  \u45336 \u50612 \u44032 \u45716  \u48516 \u50948 \u44592 \u50688 \u51648 \u47564 , \u51060 \u54980  \u44536  \u49324 \u51652 \u51008  \u49436 \u50672 \u51012  \u45440 \u47532 \u45716  \'91\u51684 \'92\u52376 \u47100  \u49324 \u50857 \u46104 \u44592  \u49884 \u51089 \u54664 \u45796 .\
\uc0\u49436 \u50672 \u51060  \u45800 \u52404  \u52292 \u54021 \u48169 \u50640  \'93\u49688 \u54665 \u54217 \u44032  \u50577 \u49885  \u50612 \u46356  \u51080 \u50612 ?\'94\u46972 \u44256  \u47931 \u51088 , \u48708 \u44277 \u44060 \u48169 \u50640 \u49436 \u45716  \u54633 \u49457  \u49324 \u51652 \u44284  \u54632 \u44760  \'93\u51656 \u47928 \u48391  \u46608  \u46321 \u51109 \'94\u51060 \u46972 \u45716  \u47700 \u49884 \u51648 \u44032  \u50732 \u46972 \u50772 \u45796 . \u49688 \u54665 \u54217 \u44032  \u48156 \u54364  \u45216 \u50640 \u45716  \u49436 \u50672 \u51060  \u48156 \u54364 \u54616 \u45716  \u46041 \u50504  \u46244 \u51901  \u54617 \u49373 \u46308 \u51060  \u55092 \u45824 \u54256 \u51012  \u48372 \u47728  \u50883 \u50632 \u44256 , \u48156 \u54364  \u51649 \u54980  \u51061 \u47749  \u51656 \u47928 \u54632 \u50640 \u45716  \'93\u51656 \u47928 \u48391 \u45784  \u48156 \u54364  \u51096  \u48420 \u49845 \u45768 \u45796 \'94\u46972 \u45716  \u44544 \u51060  \u50732 \u46972 \u50772 \u45796 . \u49436 \u50672 \u51008  \u51088 \u49888 \u51060  \u51312 \u47217 \u45817 \u54616 \u44256  \u51080 \u45796 \u45716  \u49324 \u49892 \u51012  \u50508 \u44172  \u46108  \u46244 \u48512 \u53552  \u54617 \u44368 \u50640  \u44032 \u45716  \u44163 \u51060  \u46160 \u47140 \u50892 \u51276 \u45796 .\
\uc0\u49436 \u50672 \u51032  \u52828 \u44396 \u44032  \u48708 \u44277 \u44060  \u52292 \u54021 \u48169  \u52897 \u52376 \u47484  \u49436 \u50672 \u50640 \u44172  \u48372 \u45236 \u51452 \u50632 \u44256 , \u49436 \u50672 \u51032  \u48372 \u54840 \u51088 \u44032  \u51060 \u47484  \u54617 \u44368 \u50640  \u51228 \u52636 \u54616 \u47732 \u49436  \u49888 \u44256 \u44032  \u51217 \u49688 \u46104 \u50632 \u45796 . \u54788 \u51116 \u45716  \u54617 \u44368 \u44032  \u49324 \u50504 \u51012  \u51064 \u51648 \u54616 \u44256  \u51204 \u45812 \u44592 \u44396  \u51312 \u49324 \u47484  \u49884 \u51089 \u54616 \u47140 \u45716  \u45800 \u44228 \u45796 . \u50526 \u51004 \u47196  \u44172 \u49884 \u47932  \u51089 \u49457 \u51088 , \u49324 \u51652  \u54633 \u49457 \u51088 , \u44277 \u50976 \u51088 , \u48152 \u48373 \u51201 \u51004 \u47196  \u51312 \u47217 \u50640  \u52280 \u50668 \u54620  \u54617 \u49373 \u46308 \u51012  \u44396 \u48516 \u54644  \u51312 \u49324 \u54624  \u54596 \u50836 \u44032  \u51080 \u45796 .\
