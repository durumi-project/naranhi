\f0\b \uc0\u54788 \u51116  \u51208 \u52264  \u45800 \u44228 : \u52376 \u48516  \u44208 \u51221 \'b7\u53685 \u48372 
\f1\b0 \
\uc0\u51473 \u54617 \u44368  2\u54617 \u45380  \u53468 \u54788 \u51008  4\u50900 \u48512 \u53552  \u44057 \u51008  \u48152  \u54617 \u49373  \u46160  \u47749 \u50640 \u44172  \u50837 \u49444 \u44284  \u50612 \u44648  \u48128 \u52840 \u51012  \u45817 \u54664 \u45796 . \u48373 \u46020 \u50640 \u49436  \u45336 \u50612 \u51656  \u48852 \u54620  \u46244  \u48372 \u54840 \u51088 \u50640 \u44172  \u53560 \u50612 \u45459 \u50520 \u44256 , \u48372 \u54840 \u51088 \u45716  \u54617 \u44368 \u50640  \u49888 \u44256 \u54664 \u45796 . \u54617 \u44368 \u45716  \u44288 \u47144 \u54617 \u49373 \u51012  \u48516 \u47532 \u54616 \u44256  \u51312 \u49324 \u47484  \u49884 \u51089 \u54664 \u45796 .\
\uc0\u44536 \u47084 \u45208  \u49888 \u44256  \u51060 \u54980  \u48152  \u48516 \u50948 \u44592 \u44032  \u45804 \u46972 \u51276 \u45796 . \u45800 \u52404  \u52292 \u54021 \u48169 \u50640 \u45716  \u53468 \u54788 \u51012  \u51649 \u51217  \u50616 \u44553 \u54616 \u51648  \u50506 \u50520 \u51648 \u47564  \'93\u50836 \u51608 \u51008  \u47952 \u47564  \u54616 \u47732  \u49888 \u44256 \u54620 \u45796 \'94, \'93\u44057 \u51008  \u48152 \u50640  \u44256 \u51088 \u51656 \u51137 \u51060  \u51080 \u51004 \u47732  \u54588 \u44260 \u54616 \u45796 \'94\u45716  \u44544 \u51060  \u50732 \u46972 \u50772 \u45796 . \u53468 \u54788 \u51060  \u44368 \u49892 \u50640  \u46308 \u50612 \u50724 \u47732  \u51068 \u48512  \u54617 \u49373 \u46308 \u51060  \u45824 \u54868 \u47484  \u47688 \u52676 \u44256 , \u51216 \u49900 \u49884 \u44036 \u50640 \u46020  \u44057 \u51060  \u48165 \u51012  \u47673 \u45912  \u52828 \u44396 \u46308 \u51060  \'93\u44316 \u55176  \u50670 \u51060 \u47732  \u50864 \u47532 \u46020  \u51312 \u49324 \u48155 \u45716 \u45796 \'94\u47728  \u44144 \u47532 \u47484  \u46160 \u50632 \u45796 .\
\uc0\u49900 \u51032 \u50948 \u50896 \u54924 \u45716  \u52572 \u52488  \u54253 \u47141 \u49104  \u50500 \u45768 \u46972  \u49888 \u44256  \u51060 \u54980  \u48372 \u48373 \u49457  \u48156 \u50616 \u44284  \u46384 \u46028 \u47548  \u51221 \u54889 \u46020  \u54632 \u44760  \u44160 \u53664 \u54664 \u45796 . \u54788 \u51116  \u53468 \u54788  \u52769 \u51008  \u52376 \u48516  \u44208 \u44284 \u47484  \u53685 \u48372 \u48155 \u51008  \u49345 \u53468 \u45796 . \u51068 \u48512  \u44032 \u54644 \u54617 \u49373 \u50640 \u44172 \u45716  \u51217 \u52489 \'b7\u54801 \u48149 \'b7\u48372 \u48373 \u54665 \u50948  \u44552 \u51648 \u50752  \u53945 \u48324 \u44368 \u50977  \u51312 \u52824 \u44032  \u45236 \u47140 \u51276 \u51648 \u47564 , \u53468 \u54788 \u51032  \u48372 \u54840 \u51088 \u45716  \u51312 \u52824 \u44032  \u45320 \u47924  \u50557 \u54616 \u45796 \u44256  \u45712 \u45180 \u44256  \u51080 \u50612  \u48520 \u48373  \u51208 \u52264 \u47484  \u44256 \u48124 \u54616 \u44256  \u51080 \u45796 .\
