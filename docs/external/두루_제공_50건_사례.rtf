\f1\b0 \
\uc0\u51473 \u54617 \u44368  3\u54617 \u45380  \u50696 \u51456 \u51008  \u52828 \u44396 \u50640 \u44172 \u47564  \u50508 \u47140 \u51456  \u55092 \u45824 \u54256  \u48264 \u54840 \u50752  \u51665  \u44540 \u52376  \u51221 \u48372 \u47484  \u45796 \u47480  \u54617 \u49373 \u46308 \u51060  \u50508 \u44256  \u51080 \u45796 \u45716  \u49324 \u49892 \u51012  \u50508 \u44172  \u46104 \u50632 \u45796 . \u50612 \u45712  \u45216  \u47784 \u47476 \u45716  \u48264 \u54840 \u47196  \u51109 \u45212  \u51204 \u54868 \u44032  \u50772 \u44256 , \u47700 \u49884 \u51648 \u50640 \u45716  \'93\u45320 \u55148  \u51665  \u44540 \u52376  \u48420 \u45796 \'94\u45716  \u47568 \u51060  \u51201 \u54784  \u51080 \u50632 \u45796 . \u50696 \u51456 \u51008  \u48520 \u50504 \u54644 \u49436  \u48264 \u54840 \u47484  \u52264 \u45800 \u54664 \u51648 \u47564 , \u45796 \u47480  \u48264 \u54840 \u47196 \u46020  \u48708 \u49847 \u54620  \u47700 \u49884 \u51648 \u44032  \u50772 \u45796 .\
\uc0\u45208 \u51473 \u50640  \u50696 \u51456 \u51008  \u44057 \u51008  \u48152  \u54617 \u49373 \u51060  \u48708 \u44277 \u44060  \u52292 \u54021 \u48169 \u50640  \u51088 \u49888 \u51032  \u51204 \u54868 \u48264 \u54840 \u50752  \u49324 \u45716  \u50500 \u54028 \u53944  \u51060 \u47492 \u51012  \u50732 \u47160 \u45796 \u45716  \u49324 \u49892 \u51012  \u50508 \u44172  \u46096 \u45796 . \u44536  \u54617 \u49373 \u51008  \'93\u51109 \u45212  \u51204 \u54868  \u54620  \u48264  \u54644 \u48400 \'94\u46972 \u44256  \u50044 \u44256 , \u47751 \u47751  \u54617 \u49373 \u46308 \u51060  \u49892 \u51228 \u47196  \u51204 \u54868 \u47484  \u44152 \u50632 \u45796 . \u50696 \u51456 \u51008  \u54617 \u44368 \u49104  \u50500 \u45768 \u46972  \u51665  \u51452 \u48320 \u50640 \u49436 \u46020  \u45572 \u44400 \u44032  \u51088 \u49888 \u51012  \u51648 \u53020 \u48372 \u45716  \u44163  \u44057 \u50500  \u48520 \u50504 \u54644 \u51276 \u45796 .\
