\uc0\u52488 \u46321 \u54617 \u44368  6\u54617 \u45380  \u45208 \u47532 \u45716  \u50896 \u47000  \u45348  \u47749 \u51032  \u52828 \u44396 \u46308 \u44284  \u51088 \u51452  \u50612 \u50872 \u47160 \u45796 . \u44536 \u47088 \u45936  \u50612 \u45712  \u45216  \u54620  \u52828 \u44396 \u51032  \u49373 \u51068 \u54028 \u54000 \u50640  \u45208 \u47532 \u47564  \u52488 \u45824 \u48155 \u51648  \u47803 \u54664 \u45796 . \u52488 \u45824 \u48155 \u51648  \u47803 \u54620  \u44163  \u51088 \u52404 \u48372 \u45796 , \u52828 \u44396 \u46308 \u51060  SNS\u50640  \'93\u51652 \u51676  \u52828 \u44396 \u46308 \u45180 \u47532 \u47564  \u47784 \u50688 \u45796 \'94\u45716  \u44544 \u44284  \u49324 \u51652 \u51012  \u50732 \u47536  \u44163 \u51060  \u45908  \u53360  \u49345 \u52376 \u44032  \u46104 \u50632 \u45796 .\
\uc0\u45796 \u51020  \u45216  \u54617 \u44368 \u50640 \u49436  \u52828 \u44396 \u46308 \u51008  \u45208 \u47532 \u44032  \u46308 \u51012  \u49688  \u51080 \u45716  \u44144 \u47532 \u50640 \u49436  \u49373 \u51068 \u54028 \u54000  \u51060 \u50556 \u44592 \u47484  \u44228 \u49549 \u54664 \u45796 . \'93\u52488 \u45824 \u54620  \u49324 \u46988 \u47564  \u50752 \u49436  \u51339 \u50520 \u45796 \'94, \'93\u48516 \u50948 \u44592  \u44648 \u45716  \u50528  \u50630 \u50612 \u49436  \u51116 \u48140 \u50632 \u45796 \'94\u45716  \u47568 \u46020  \u54664 \u45796 . \u51060 \u54980  \u45796 \u47480  \u50557 \u49549 \u50640 \u49436 \u46020  \u45208 \u47532 \u47564  \u48736 \u51276 \u44256 , \u45208 \u47532 \u44032  \u45796 \u44032 \u44032 \u47732  \u52828 \u44396 \u46308 \u51008  \u47568 \u51012  \u47688 \u52676 \u45796 .\
\uc0\u51204 \u45812 \u44592 \u44396  \u51312 \u49324 \u45716  \u45149 \u45228 \u44256 , \u54788 \u51116  \u49900 \u51032 \u50948 \u50896 \u54924 \u44032  \u51068 \u51452 \u51068  \u51060 \u45236 \u47196  \u50696 \u51221 \u46104 \u50612  \u51080 \u45796 . \u45208 \u47532  \u52769 \u51008  SNS \u44172 \u49884 \u47932 , \u45800 \u52404  \u52292 \u54021 \u48169  \u45824 \u54868 , \u54617 \u44368 \u50640 \u49436  \u46308 \u51008  \u48156 \u50616 \u51012  \u51221 \u47532 \u54616 \u44256  \u51080 \u45796 . \u51060  \u49324 \u47168 \u45716  \u45800 \u49692 \u55176  \u49373 \u51068 \u54028 \u54000 \u50640  \u52488 \u45824 \u54616 \u51648  \u50506 \u51008  \u47928 \u51228 \u44032  \u50500 \u45768 \u46972 , \u48176 \u51228  \u49324 \u49892 \u51012  \u44284 \u49884 \u54616 \u44256  \u54617 \u44368 \u49373 \u54876 \u50640 \u49436  \u48152 \u48373 \u51201 \u51004 \u47196  \u44256 \u47549 \u49884 \u53416  \u51216 \u51060  \u54645 \u49900 \u51060 \u45796 .\
