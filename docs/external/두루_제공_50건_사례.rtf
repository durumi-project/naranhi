\uc0\u44256 \u46321 \u54617 \u44368  1\u54617 \u45380  \u53468 \u47532 \u45716  \u50689 \u50612  \u47568 \u54616 \u44592  \u49688 \u54665 \u54217 \u44032 \u50640 \u49436  \u48156 \u54364  \u50689 \u49345 \u51012  \u51228 \u52636 \u54664 \u45796 . \u44057 \u51008  \u51312  \u54617 \u49373 \u51060  \u51088 \u47308  \u51221 \u47532 \u47484  \u50948 \u54644  \u50689 \u49345 \u51012  \u48155 \u50520 \u45716 \u45936 , \u44536 \u51473  \u53468 \u47532 \u44032  \u48156 \u51020 \u51012  \u49892 \u49688 \u54620  \u48512 \u48516 \u47564  \u51096 \u46972  \u54200 \u51665 \u54664 \u45796 . \u51060 \u54980  \'93\u50896 \u50612 \u48124  \u52649 \u44201  \u48156 \u51020 \'94\u51060 \u46972 \u45716  \u51088 \u47561 \u51012  \u48537 \u50668  \u52828 \u44396 \u46308 \u50640 \u44172  \u44277 \u50976 \u54664 \u45796 .\
\uc0\u52376 \u51020 \u50640 \u45716  \u47751  \u47749 \u51060  \u50883 \u44256  \u45149 \u45208 \u45716  \u46319 \u54664 \u51648 \u47564 , \u45208 \u51473 \u50640 \u45716  \u53468 \u47532 \u44032  \u50689 \u50612  \u49884 \u44036 \u50640  \u48156 \u54364 \u54624  \u46412 \u47560 \u45796  \u54617 \u49373 \u46308 \u51060  \u51068 \u48512 \u47084  \u44536  \u48156 \u51020 \u51012  \u46384 \u46972  \u54664 \u45796 . \u53468 \u47532 \u45716  \u50689 \u50612  \u49688 \u50629 \u50640 \u49436  \u47568 \u54616 \u45716  \u44163 \u51012  \u54588 \u54616 \u44172  \u46104 \u50632 \u44256 , \u49688 \u54665 \u54217 \u44032  \u52280 \u50668 \u50640 \u46020  \u48520 \u50504 \u44048 \u51012  \u45712 \u44808 \u45796 .\
\uc0\u54617 \u44368 \u45716  \u49888 \u44256 \u47484  \u48155 \u44256  \u51204 \u45812 \u44592 \u44396  \u51312 \u49324 \u47484  \u47560 \u52452 \u44256 , \u54788 \u51116  \u49900 \u51032 \u50948 \u50896 \u54924  \u52636 \u49437  \u53685 \u48372 \u44032  \u51060 \u47336 \u50612 \u51652  \u49345 \u53468 \u45796 . \u51060  \u49324 \u47168 \u45716  \u54617 \u49845  \u44284 \u51221 \u50640 \u49436 \u51032  \u49892 \u49688 \u47484  \u50501 \u51032 \u51201 \u51004 \u47196  \u54200 \u51665 \u54644  \u51312 \u47217 \u54620  \u49324 \u51060 \u48260 \u54253 \u47141 \u51060 \u45796 .\
