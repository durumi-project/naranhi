\uc0\u52376 \u51020 \u50640 \u45716  \u49552 \u48148 \u45797 \u51004 \u47196  \u44032 \u48333 \u44172  \u52824 \u45716  \u51221 \u46020 \u50688 \u51648 \u47564 , \u45208 \u51473 \u50640 \u45716  \u48373 \u46020 \u50640 \u49436  \u48156 \u51012  \u44152 \u44144 \u45208  \u51032 \u51088 \u47484  \u48764 \u45716  \u54665 \u46041 \u51004 \u47196  \u51060 \u50612 \u51276 \u45796 . \u50612 \u45712  \u45216  \u44148 \u50864 \u44032  \u51032 \u51088 \u50640  \u50505 \u51004 \u47140 \u45716  \u49692 \u44036  \u45572 \u44400 \u44032  \u51032 \u51088 \u47484  \u46244 \u47196  \u48764 \u49436  \u44148 \u50864 \u44032  \u48148 \u45797 \u50640  \u45336 \u50612 \u51276 \u44256 , \u54728 \u47532 \u47484  \u45796 \u52452 \u45796 . \u51452 \u48320  \u54617 \u49373 \u46308 \u51008  \u50883 \u50632 \u51648 \u47564  \u44148 \u50864 \u45716  \u48372 \u44148 \u49892 \u50640  \u44052 \u45796 .\
\uc0\u48372 \u54840 \u51088 \u45716  \u48372 \u44148 \u49892  \u44592 \u47197 \u51012  \u48372 \u44256  \u54617 \u44368 \u50640  \u47928 \u51032 \u54664 \u44256 , \u44148 \u50864 \u45716  \u44536 \u46041 \u50504  \u48152 \u48373 \u51201 \u51004 \u47196  \u49888 \u52404 \u51201  \u44340 \u47213 \u55192 \u51012  \u45817 \u54664 \u45796 \u44256  \u47568 \u54664 \u45796 . \u54788 \u51116  \u54617 \u44368  \u51204 \u45812 \u44592 \u44396 \u45716  \u44368 \u49892  CCTV, \u48372 \u44148 \u49892  \u44592 \u47197 , \u51452 \u48320  \u54617 \u49373  \u51652 \u49696 \u51012  \u54869 \u51064 \u54616 \u44256  \u51080 \u45796 . \u51060  \u49324 \u44148 \u51008  \u54620  \u48264 \u51032  \u53360  \u54253 \u54665 \u48372 \u45796  \'93\u51109 \u45212 \'94\u51060 \u46972 \u45716  \u51060 \u47492 \u51004 \u47196  \u48152 \u48373 \u46108  \u49888 \u52404  \u51217 \u52489 \u51060  \u54645 \u49900 \u51060 \u45796 .\
