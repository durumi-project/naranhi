\outl0\strokewidth0 \strokec2 1. \uc0\u47568 \u53804  \u51312 \u47217 \u50640 \u49436  \u49884 \u51089 \u46108  \u51665 \u45800 \u46384 \u46028 \u47548 \
\pard\pardeftab720\sa240\partightenfactor0

\fs24 \cf2 \uc0\u52852 \u53580 \u44256 \u47532 : \u50616 \u50612 \u54253 \u47141 , \u51665 \u45800 \u46384 \u46028 \u47548 , \u49324 \u51060 \u48260  \u51312 \u47217 
\f1\b0 \uc0\u8232 
\f0\b \uc0\u54788 \u51116  \u51208 \u52264  \u45800 \u44228 : \u49324 \u49892  \u54869 \u51064  \u51312 \u49324  \u51473 
\f1\b0 \
\uc0\u51473 \u54617 \u44368  1\u54617 \u45380  \u48124 \u51116 \u45716  3\u50900 \u50640  \u51204 \u54617 \u51012  \u50772 \u45796 . \u52376 \u51020 \u50640 \u45716  \u47568 \u49688 \u44032  \u51201 \u44256  \u48156 \u54364 \u54624  \u46412  \u47785 \u49548 \u47532 \u44032  \u51089 \u45796 \u45716  \u51060 \u50976 \u47196  \u47751 \u47751  \u54617 \u49373 \u46308 \u51060  \u48124 \u51116 \u51032  \u47568 \u53804 \u47484  \u46384 \u46972  \u54664 \u45796 . \u44397 \u50612  \u49884 \u44036 \u50640  \u48124 \u51116 \u44032  \u52293 \u51012  \u51069 \u45796 \u44032  \u51104 \u44624  \u47568 \u51012  \u45908 \u46316 \u51088  \u46244 \u51901 \u50640 \u49436  \'93\u48260 \u54140 \u47553  \u44152 \u47160 \u45796 \'94\u45716  \u47568 \u51060  \u45208 \u50772 \u44256 , \u51452 \u48320  \u54617 \u49373 \u46308 \u51060  \u50883 \u50632 \u45796 . \u44536 \u45216  \u51060 \u54980  \u48124 \u51116 \u50640 \u44172 \u45716  \'93\u47196 \u48391 \'94, \'93NPC\'94, \'93\u44256 \u51109 \u45212  AI\'94 \u44057 \u51008  \u48324 \u47749 \u51060  \u48537 \u50632 \u45796 .\
\uc0\u52376 \u51020 \u50640 \u45716  \u49772 \u45716  \u49884 \u44036 \u47560 \u45796  \u54620 \u46160  \u48264  \u45440 \u47532 \u45716  \u51221 \u46020 \u50688 \u51648 \u47564 , \u49884 \u44036 \u51060  \u51648 \u45208 \u47732 \u49436  \u45440 \u47548 \u51008  \u48152  \u48516 \u50948 \u44592  \u51204 \u52404 \u47196  \u54140 \u51276 \u45796 . \u44553 \u49885  \u49884 \u44036 \u50640 \u45716  \u48124 \u51116 \u44032  \u50505 \u51004 \u47140  \u54616 \u47732  \'93\u51088 \u47532  \u51080 \u45796 \'94\u47728  \u44032 \u48169 \u51012  \u50732 \u47140 \u46160 \u50632 \u44256 , \u52404 \u50977  \u49884 \u44036  \u54016 \u51012  \u51684  \u46412 \u46020  \u48124 \u51116 \u45716  \u54637 \u49345  \u47560 \u51648 \u47561 \u50640  \u45224 \u50520 \u45796 . \u48152  \u45800 \u52404  \u52292 \u54021 \u48169 \u50640 \u49436 \u45716  \u48124 \u51116 \u44032  \u49689 \u51228 \u47484  \u47932 \u50612 \u48372 \u47732  \u50500 \u47924 \u46020  \u45813 \u54616 \u51648  \u50506 \u50520 \u51648 \u47564 , \u48324 \u46020 \u51032  \u52292 \u54021 \u48169 \u50640 \u49436 \u45716  \u48124 \u51116 \u51032  \u51656 \u47928 \u51012  \u52897 \u52376 \u54644  \'93NPC \u53272 \u49828 \u53944  \u50836 \u52397 \'94\u51060 \u46972 \u44256  \u51312 \u47217 \u54664 \u45796 .\
\uc0\u48124 \u51116 \u45716  5\u50900 \u48512 \u53552  \u46321 \u44368  \u51204 \u47560 \u45796  \u48176 \u44032  \u50500 \u54532 \u45796 \u44256  \u54664 \u44256 , \u44208 \u44397  \u48372 \u54840 \u51088 \u44032  \u48124 \u51116 \u51032  \u54596 \u53685 \u50640 \u49436  \'93\u47568 \u54616 \u51648  \u47560 . \u51116 \u48120 \u50630 \u50612 .\'94\u46972 \u44256  \u51201 \u55180  \u51901 \u51648 \u47484  \u48156 \u44204 \u54616 \u47732 \u49436  \u54617 \u44368 \u50640  \u49888 \u44256 \u54664 \u45796 . \u54788 \u51116  \u54617 \u44368  \u51204 \u45812 \u44592 \u44396 \u45716  \u45800 \u52404  \u52292 \u54021 \u48169  \u52897 \u52376 , \u51901 \u51648 , \u51452 \u48320  \u54617 \u49373  \u51652 \u49696 , \u48124 \u51116 \u51032  \u49345 \u45812  \u44592 \u47197 \u51012  \u48148 \u53461 \u51004 \u47196  \u49324 \u49892  \u54869 \u51064  \u51312 \u49324 \u47484  \u51652 \u54665  \u51473 \u51060 \u45796 . \u51060  \u49324 \u44148 \u51008  \u44169 \u51004 \u47196 \u45716  \u51109 \u45212 \u52376 \u47100  \u48372 \u51060 \u51648 \u47564 , \u48152 \u48373 \u51201  \u50616 \u50612 \u54253 \u47141 \u44284  \u51665 \u45800 \u51201  \u48176 \u51228 \u44032  \u44208 \u54633 \u46108  \u49324 \u47168 \u45796 .\
