\f0\b\fs36 \cf2 \strokec2 3. \'93\uc0\u46024  \u51328  \u48716 \u47140 \u51480 \'94\u50640 \u49436  \u49884 \u51089 \u46108  \u44552 \u54408 \u44040 \u52712 \
\pard\pardeftab720\sa240\partightenfactor0

\fs24 \cf2 \uc0\u52852 \u53580 \u44256 \u47532 : \u44552 \u54408 \u44040 \u52712 , \u44053 \u50836 , \u54801 \u48149 \u49457  \u44288 \u44228 
\f1\b0 \uc0\u8232 
\f0\b \uc0\u54788 \u51116  \u51208 \u52264  \u45800 \u44228 : \u54617 \u44368 \u51109  \u51088 \u52404 \u54644 \u44208  \u44160 \u53664 
\f1\b0 \
\uc0\u51473 \u54617 \u44368  2\u54617 \u45380  \u46020 \u50980 \u51008  \u47588 \u51216 \u50640  \u51088 \u51452  \u44032 \u45716  \u54200 \u51060 \u50632 \u45796 . \u44057 \u51008  \u54617 \u45380  \u54788 \u50864 \u45716  \u52376 \u51020 \u50640  \'93500\u50896 \u47564  \u48716 \u47140 \u51480 . \u45236 \u51068  \u51460 \u44172 \'94\u46972 \u44256  \u54664 \u45796 . \u46020 \u50980 \u51008  \u44144 \u51208 \u54616 \u44592  \u50528 \u47588 \u54644 \u49436  \u46024 \u51012  \u51500 \u51648 \u47564 , \u54788 \u50864 \u45716  \u46024 \u51012  \u44058 \u51648  \u50506 \u50520 \u45796 . \u45796 \u51020  \u45216 \u50640 \u45716  \'93\u50724 \u45720 \u51008  \u51020 \u47308 \u49688  \u54616 \u45208 \u47564  \u49324 \u51480 \'94\u46972 \u44256  \u54664 \u44256 , \u46020 \u50980 \u51060  \u47672 \u47943 \u44144 \u47532 \u51088  \'93\u45320  \u51665  \u51096 \u49328 \u45796 \u47728 . \u44536  \u51221 \u46020 \u46020  \u50500 \u44637 \u45264 ?\'94\u46972 \u44256  \u47568 \u54664 \u45796 .\
\uc0\u50836 \u44396 \u45716  \u51216 \u51216  \u52964 \u51276 \u45796 . \u54788 \u50864 \u50752  \u44536  \u52828 \u44396 \u46308 \u51008  \u46020 \u50980 \u50640 \u44172  \u47588 \u51216  \u51020 \u49885 , \u44368 \u53685 \u52852 \u46300  \u52649 \u51204 , \u47784 \u48148 \u51068  \u44172 \u51076  \u50500 \u51060 \u53596  \u44208 \u51228 \u47484  \u50836 \u44396 \u54664 \u45796 . \u45208 \u51473 \u50640 \u45716  \u46020 \u50980 \u50640 \u44172  \u51088 \u49888 \u51032  \u44284 \u54617  \u49688 \u54665 \u54217 \u44032  \u51088 \u47308 \u47484  \u45824 \u49888  \u51221 \u47532 \u54616 \u46972 \u44256  \u54664 \u45796 . \u46020 \u50980 \u51060  \u44144 \u51208 \u54616 \u51088  \u54788 \u50864 \u45716  \'93\u45348 \u44032  \u50864 \u47532 \u54620 \u53580  \u48537 \u51004 \u47140 \u44256  \u47676 \u51200  \u49324 \u51456  \u44144 \u46972 \u44256  \u47568 \u54616 \u47732  \u46104 \u51648 \'94\u46972 \u47728  \u50517 \u48149 \u54664 \u45796 . \u46020 \u50980 \u51008  \u51088 \u49888 \u51060  \u48520 \u47532 \u54644 \u51656 \u44620  \u48400  \u44228 \u49549  \u50836 \u44396 \u47484  \u46308 \u50612 \u51452 \u50632 \u45796 .\
\uc0\u48372 \u54840 \u51088 \u45716  \u52852 \u46300  \u44208 \u51228  \u45236 \u50669 \u44284  \u54200 \u51032 \u51216  \u50689 \u49688 \u51613 \u51012  \u54869 \u51064 \u54616 \u44256  \u54617 \u44368 \u50640  \u49888 \u44256 \u54664 \u45796 . \u51204 \u45812 \u44592 \u44396  \u51312 \u49324 \u45716  \u50612 \u45712  \u51221 \u46020  \u45149 \u45228 \u44256 , \u54617 \u44368 \u45716  \u54788 \u51116  \u51060  \u49324 \u50504 \u51060  \u54617 \u44368 \u51109  \u51088 \u52404 \u54644 \u44208 \u47196  \u44032 \u45733 \u54620 \u51648  \u44160 \u53664  \u51473 \u51060 \u45796 . \u44536 \u47084 \u45208  \u44552 \u51204  \u54588 \u54644 \u44032  \u48152 \u48373 \u46104 \u50632 \u44256 , \u44053 \u50836 \u50752  \u54801 \u48149 \u49457  \u48156 \u50616 \u51060  \u51080 \u50632 \u44592  \u46412 \u47928 \u50640  \u44221 \u48120 \u49324 \u50504 \u51004 \u47196  \u48372 \u44592  \u50612 \u47140 \u50872  \u49688  \u51080 \u45796 .\
