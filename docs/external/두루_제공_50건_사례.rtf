\f1\b0 \
\uc0\u51473 \u54617 \u44368  3\u54617 \u45380  \u54616 \u47536 \u51008  \u44057 \u51008  \u54617 \u45380  \u45224 \u54617 \u49373 \u44284  \u52828 \u54616 \u44172  \u51648 \u45256 \u45796 . \u46168 \u51008  \u49892 \u51228 \u47196  \u49324 \u44480 \u45716  \u49324 \u51060 \u44032  \u50500 \u45768 \u50632 \u51648 \u47564 , \u47751 \u47751  \u54617 \u49373 \u46308 \u51060  \'93\u46168 \u51060  \u49324 \u44484 \u45796 \u45908 \u46972 \'94\u45716  \u47568 \u51012  \u54140 \u46888 \u47532 \u44592  \u49884 \u51089 \u54664 \u45796 . \u52376 \u51020 \u50640 \u45716  \'93\u45224 \u52828  \u50612 \u46356  \u44052 \u50612 ?\'94 \u44057 \u51008  \u45440 \u47548 \u51060 \u50632 \u51648 \u47564 , \u49884 \u44036 \u51060  \u51648 \u45208 \u47732 \u49436  \u49548 \u47928 \u51008  \u49457 \u51201 \u51064  \u48169 \u54693 \u51004 \u47196  \u48320 \u54664 \u45796 .\
\uc0\u51061 \u47749 \u44172 \u49884 \u54032 \u50640 \u45716  \u54616 \u47536 \u51032  \u51060 \u47492  \u52488 \u49457 \u44284  \u54632 \u44760  \u47784 \u50837 \u51201 \u51064  \u44544 \u51060  \u50732 \u46972 \u50772 \u45796 . \u45843 \u44544 \u50640 \u45716  \'93\u50612 \u51228 \u46020  \u44057 \u51060  \u51080 \u50632 \u45796 \u45912 \u45936 \'94 \u44057 \u51008  \u47568 \u51060  \u45804 \u47160 \u45796 . \u54616 \u47536 \u51060  \u44544 \u51012  \u45236 \u47140 \u45804 \u46972 \u44256  \u54616 \u51088  \u51089 \u49457 \u51088 \u45716  \'93\u52244 \u47532 \u45768 \u44620  \u44536 \u47084 \u45716  \u44144 \u45264 \'94\u44256  \u45813 \u54664 \u45796 . \u51060 \u54980  \u54616 \u47536 \u51060  \u48373 \u46020 \u47484  \u51648 \u45208 \u44032 \u47732  \u47751 \u47751  \u54617 \u49373 \u46308 \u51060  \u51068 \u48512 \u47084  \u50883 \u44144 \u45208  \u49688 \u44400 \u44144 \u47160 \u44256 , \u54616 \u47536 \u51008  \u52404 \u50977 \u48373 \u51012  \u44040 \u50500 \u51077 \u45716  \u49884 \u44036 \u50640 \u46020  \u45572 \u44032  \u51088 \u49888 \u51012  \u52237 \u51012 \u44620  \u48400  \u48520 \u50504 \u54644 \u54664 \u45796 .\
\uc0\u49345 \u45812 \u44368 \u49324 \u44032  \u54616 \u47536 \u51032  \u49345 \u53468 \u47484  \u54869 \u51064 \u54616 \u44256  \u48372 \u54840 \u51088 \u50640 \u44172  \u50672 \u46973 \u54664 \u44256 , \u48372 \u54840 \u51088 \u45716  \u54617 \u44368 \u50640  \u49888 \u44256 \u54664 \u45796 . \u51204 \u45812 \u44592 \u44396  \u51312 \u49324 \u44032  \u45149 \u45228 \u44256 , \u54788 \u51116  \u49900 \u51032 \u50948 \u50896 \u54924 \u44032  \u51068 \u51452 \u51068  \u46244 \u47196  \u50696 \u51221 \u46104 \u50612  \u51080 \u45796 . \u54616 \u47536  \u52769 \u51008  \u51061 \u47749 \u44172 \u49884 \u54032  \u52897 \u52376 , \u45843 \u44544 , \u49345 \u45812  \u44592 \u47197 , \u51452 \u48320  \u54617 \u49373  \u51652 \u49696 \u51012  \u51221 \u47532 \u54616 \u44256  \u51080 \u45796 . \u51060  \u49324 \u47168 \u45716  \u49457 \u51201  \u49548 \u47928 , \u50728 \u46972 \u51064  \u47784 \u50837 , \u51452 \u48320  \u54617 \u49373 \u46308 \u51032  2\u52264  \u44032 \u54644 \u44032  \u44208 \u54633 \u46108  \u49324 \u44148 \u51060 \u45796 .\
