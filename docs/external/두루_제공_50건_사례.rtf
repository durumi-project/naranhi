\f1\b0 \uc0\u8232 
\f0\b \uc0\u54788 \u51116  \u51208 \u52264  \u45800 \u44228 : \u54617 \u44368 \u51109  \u51088 \u52404 \u54644 \u44208  \u44160 \u53664 
\f1\b0 \
\uc0\u44256 \u46321 \u54617 \u44368  2\u54617 \u45380  \u45208 \u51008 \u44284  \u49548 \u46972 \u45716  1\u54617 \u45380  \u46412  \u44032 \u51109  \u52828 \u54620  \u52828 \u44396 \u50688 \u45796 . \u54616 \u51648 \u47564  2\u54617 \u45380 \u51060  \u46104 \u47732 \u49436  \u45208 \u51008 \u51060  \u45796 \u47480  \u52828 \u44396 \u46308 \u44284 \u46020  \u50612 \u50872 \u47532 \u44592  \u49884 \u51089 \u54616 \u51088  \u49548 \u46972 \u45716  \u48176 \u49888 \u44048 \u51012  \u45712 \u44808 \u45796 . \u52376 \u51020 \u50640 \u45716  \'93\u50780  \u45208  \u48764 \u44256  \u48165  \u47673 \u50612 ?\'94\u46972 \u45716  \u47700 \u49884 \u51648 \u50688 \u51648 \u47564 , \u51216 \u51216  \u54616 \u47336  \u49688 \u49901  \u44060 \u51032  \u50672 \u46973 \u51004 \u47196  \u48148 \u45068 \u50632 \u45796 .\
\uc0\u45208 \u51008 \u51060  \u45813 \u54616 \u51648  \u50506 \u51004 \u47732  \u49548 \u46972 \u45716  \'93\u51069 \u50489 \u54664 \u45348 \'94, \'93\u45320  \u50896 \u47000  \u44536 \u47088  \u50528 \u50688 \u44396 \u45208 \'94\u46972 \u44256  \u48372 \u45256 \u45796 . \u45208 \u51008 \u51060  SNS\u50640  \u45796 \u47480  \u52828 \u44396 \u46308 \u44284  \u52237 \u51008  \u49324 \u51652 \u51012  \u50732 \u47532 \u47732  \'93\u50724 \u45720  \u50612 \u46356  \u44052 \u45348 ?\'94, \'93\u45208 \u45716  \u48260 \u47532 \u44256  \u51116 \u48140 \u45264 \'94\u45716  \u47700 \u49884 \u51648 \u44032  \u50772 \u45796 . \u45208 \u51473 \u50640 \u45716  \u45208 \u51008 \u51060  \u45796 \u45768 \u45716  \u54617 \u50896  \u50526 \u50640 \u49436  \u44592 \u45796 \u47532 \u44592 \u46020  \u54664 \u45796 . \u45208 \u51008 \u51008  \u47924 \u49453 \u45796 \u44256  \u45712 \u44808 \u51648 \u47564 , \u50696 \u51204 \u50640  \u52828 \u54664 \u45912  \u52828 \u44396 \u46972  \u49888 \u44256 \u54616 \u44592  \u47581 \u49444 \u50688 \u45796 .\
\uc0\u44208 \u44397  \u49548 \u46972 \u44032  SNS\u50640  \'93\u49324 \u46988  \u44040 \u50500 \u53440 \u45716  \u50528 \'94\u46972 \u45716  \u44544 \u51012  \u50732 \u47532 \u47732 \u49436  \u49324 \u44148 \u51060  \u54617 \u44368 \u50640  \u50508 \u47140 \u51276 \u45796 . \u51204 \u45812 \u44592 \u44396 \u45716  \u46160  \u54617 \u49373 \u51032  \u44288 \u44228  \u48320 \u54868 , \u48152 \u48373  \u50672 \u46973 , \u44144 \u48512  \u51032 \u49324 , SNS \u44172 \u49884 \u44544 \u51012  \u51312 \u49324 \u54664 \u45796 . \u54788 \u51116  \u54617 \u44368 \u45716  \u54617 \u44368 \u51109  \u51088 \u52404 \u54644 \u44208 \u51060  \u44032 \u45733 \u54620 \u51648  \u44160 \u53664  \u51473 \u51060 \u51648 \u47564 , \u45208 \u51008 \u51060  \u47749 \u54869 \u55176  \u44144 \u48512 \u54664 \u51020 \u50640 \u46020  \u50672 \u46973 \u44284  \u44048 \u49884 \u44032  \u44228 \u49549 \u46104 \u50632 \u45796 \u45716  \u51216  \u46412 \u47928 \u50640  \u49900 \u51032 \u50948  \u54924 \u48512  \u44032 \u45733 \u49457 \u46020  \u51080 \u45796 .\
