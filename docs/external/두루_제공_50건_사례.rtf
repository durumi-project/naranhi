\uc0\u51473 \u54617 \u44368  3\u54617 \u45380  \u50976 \u45208 \u45716  \u48152 \u51109  \u49440 \u44144 \u50640  \u52636 \u47560 \u54644  \u45817 \u49440 \u46104 \u50632 \u45796 . \u44536 \u47088 \u45936  \u54632 \u44760  \u52636 \u47560 \u54664 \u45912  \u45796 \u47480  \u54617 \u49373 \u51032  \u52828 \u44396 \u46308 \u51060  \u44208 \u44284 \u50640  \u48520 \u47564 \u51012  \u54408 \u50632 \u45796 . \u52376 \u51020 \u50640 \u45716  \'93\u51172 \u44032  \u50780  \u48152 \u51109 \u51060 \u45264 \'94\u45716  \u47568 \u51060  \u45208 \u50772 \u44256 , \u51060 \u54980  \u50976 \u45208 \u44032  \u54617 \u44553  \u44277 \u51648 \u47484  \u54616 \u47732  \u51068 \u48512  \u54617 \u49373 \u46308 \u51060  \u51068 \u48512 \u47084  \u45813 \u54616 \u51648  \u50506 \u50520 \u45796 .\
\uc0\u54617 \u44553  \u45800 \u52404  \u52292 \u54021 \u48169 \u50640 \u49436 \u45716  \u50976 \u45208 \u44032  \u44277 \u51648 \u47484  \u50732 \u47140 \u46020  \u51069 \u44256  \u47924 \u49884 \u54616 \u45716  \u51068 \u51060  \u48152 \u48373 \u46096 \u45796 . \u47751 \u47751  \u54617 \u49373 \u46308 \u51008  \u48324 \u46020 \u51032  \u52292 \u54021 \u48169 \u51012  \u47564 \u46308 \u50612  \u50976 \u45208 \u44032  \u49892 \u49688 \u54624  \u46412 \u47560 \u45796  \u52897 \u52376 \u54644  \u51312 \u47217 \u54664 \u45796 . \u50976 \u45208 \u44032  \u54617 \u44553 \u54924 \u51032 \u50640 \u49436  \u51032 \u44204 \u51012  \u45236 \u47732  \'93\u54844 \u51088  \u51096 \u45212  \u52377 \u54620 \u45796 \'94\u45716  \u47568 \u51060  \u45208 \u50772 \u44256 , \u49688 \u54665 \u54217 \u44032  \u51312 \u47484  \u51684  \u46412 \u46020  \u50976 \u45208 \u45716  \u51032 \u46020 \u51201 \u51004 \u47196  \u48176 \u51228 \u46096 \u45796 .\
\uc0\u50976 \u45208 \u51032  \u48372 \u54840 \u51088 \u44032  \u54617 \u44368 \u50640  \u49888 \u44256 \u54664 \u44256 , \u49900 \u51032 \u50948 \u50896 \u54924 \u45716  \u51060  \u49324 \u44148 \u51012  \u45800 \u49692 \u54620  \u49440 \u44144  \u44040 \u46321 \u51060  \u50500 \u45768 \u46972  \u51312 \u51649 \u51201  \u48176 \u52377 \u44284  \u54217 \u54032  \u55036 \u49552 \u51004 \u47196  \u48372 \u50520 \u45796 . \u54788 \u51116  \u50976 \u45208  \u52769 \u51008  \u52376 \u48516  \u44208 \u44284 \u47484  \u53685 \u48372 \u48155 \u50520 \u45796 . \u51068 \u48512  \u54617 \u49373 \u50640 \u44172 \u45716  \u49436 \u47732 \u49324 \u44284 , \u51217 \u52489 \u44552 \u51648 , \u53945 \u48324 \u44368 \u50977  \u51312 \u52824 \u44032  \u45236 \u47140 \u51276 \u51648 \u47564 , \u54617 \u44553  \u48516 \u50948 \u44592  \u54924 \u48373 \u51060  \u50668 \u51204 \u55176  \u51473 \u50836 \u54620  \u44284 \u51228 \u47196  \u45224 \u50500  \u51080 \u45796 .\
