\f1\b0 \
\uc0\u44256 \u46321 \u54617 \u44368  1\u54617 \u45380  \u48124 \u49436 \u45716  \u44057 \u51008  \u48152  \u54617 \u49373 \u50640 \u44172  \u51648 \u49549 \u51201 \u51004 \u47196  \u50837 \u49444 \u44284  \u47784 \u50837 \u51012  \u46308 \u50632 \u45796 \u44256  \u49888 \u44256 \u54664 \u45796 . \u51204 \u45812 \u44592 \u44396  \u51312 \u49324  \u44208 \u44284  \u51068 \u48512  \u50837 \u49444 \u44284  \u51312 \u47217 \u51060  \u54869 \u51064 \u46104 \u50632 \u44256 , \u49900 \u51032 \u50948 \u50896 \u54924 \u45716  \u44032 \u54644 \u54617 \u49373 \u50640 \u44172  \u49436 \u47732 \u49324 \u44284 \u50752  \u53945 \u48324 \u44368 \u50977  \u51312 \u52824 \u47484  \u44208 \u51221 \u54664 \u45796 .\
\uc0\u44536 \u47084 \u45208  \u52376 \u48516  \u51060 \u54980  \u44032 \u54644 \u54617 \u49373  \u52769 \u51008  \'93\u48124 \u49436 \u44032  \u44284 \u51109 \u54644 \u49436  \u49888 \u44256 \u54664 \u45796 \'94, \'93\u44144 \u51667 \u47568 \u47196  \u49324 \u46988 \u51012  \u54617 \u54253  \u44032 \u54644 \u51088 \u47196  \u47564 \u46308 \u50632 \u45796 \'94\u45716  \u47568 \u51012  \u51452 \u48320 \u50640  \u54140 \u46888 \u47160 \u45796 . \u47751 \u47751  \u54617 \u49373 \u46308 \u51008  \u48124 \u49436 \u47484  \u54693 \u54644  \'93\u49888 \u44256 \u54616 \u47732  \u51060 \u44592 \u45716  \u51460  \u50500 \u45264 \'94, \'93\u51613 \u44144 \u46020  \u48324 \u47196  \u50630 \u50632 \u45796 \u47728 \'94\u46972 \u44256  \u47568 \u54664 \u45796 . \u48124 \u49436 \u45716  \u52376 \u48516 \u51012  \u48155 \u50520 \u51020 \u50640 \u46020  \u50724 \u55176 \u47140  \u45908  \u44256 \u47549 \u46104 \u50632 \u45796 .\
\uc0\u44032 \u54644 \u54617 \u49373  \u52769  \u48372 \u54840 \u51088 \u45716  \u52376 \u48516 \u50640  \u48520 \u48373 \u54644  \u54665 \u51221 \u49900 \u54032 \u51012  \u52397 \u44396 \u54664 \u44256 , \u48124 \u49436  \u52769 \u46020  \u49888 \u44256  \u51060 \u54980 \u51032  \u48372 \u48373 \u49457  \u48156 \u50616 \u51012  \u52628 \u44032 \u47196  \u47928 \u51228  \u49340 \u44256  \u51080 \u45796 . \u54788 \u51116  \u49324 \u44148 \u51008  \u48520 \u48373  \u51208 \u52264 \u44032  \u51652 \u54665  \u51473 \u51060 \u47728 , \u48124 \u49436  \u52769 \u51008  \u52572 \u52488  \u54588 \u54644 \u49104  \u50500 \u45768 \u46972  \u52376 \u48516  \u51060 \u54980  \u48156 \u49373 \u54620  2\u52264  \u54588 \u54644  \u51088 \u47308 \u47484  \u51221 \u47532 \u54616 \u44256  \u51080 \u45796 . \u51060  \u49324 \u47168 \u45716  \u49900 \u51032 \u44032  \u45149 \u45212  \u46244 \u50640 \u46020  \u54588 \u54644 \u44032  \u44228 \u49549 \u46112  \u49688  \u51080 \u51020 \u51012  \u48372 \u50668 \u51456 \u45796 .\
