\uc0\u51473 \u54617 \u44368  2\u54617 \u45380  \u47196 \u50868 \u51008  \u44057 \u51008  \u54617 \u44368  \u52828 \u44396 \u46308 \u44284  \u50728 \u46972 \u51064  \u44172 \u51076 \u51012  \u54664 \u45796 . \u44172 \u51076  \u50504 \u50640 \u49436  \u50500 \u51060 \u53596  \u48516 \u48176  \u47928 \u51228 \u47196  \u44040 \u46321 \u51060  \u49373 \u44220 \u44256 , \u47196 \u50868 \u51008  \u44600 \u46300  \u52292 \u54021 \u48169 \u50640 \u49436  \u54620  \u52828 \u44396 \u50752  \u47568 \u45796 \u53820 \u51012  \u54664 \u45796 . \u47928 \u51228 \u45716  \u44536  \u44040 \u46321 \u51060  \u54617 \u44368 \u49373 \u54876 \u47196  \u51060 \u50612 \u51276 \u45796 \u45716  \u51216 \u51060 \u50632 \u45796 .\
\uc0\u45796 \u51020  \u45216  \u54617 \u44368 \u50640 \u49436  \u47751 \u47751  \u54617 \u49373 \u46308 \u51008  \u47196 \u50868 \u51012  \'93\u47673 \u53888 \'94, \'93\u48176 \u49888 \u51088 \'94\u46972 \u44256  \u48520 \u47104 \u45796 . \u44172 \u51076  \u52292 \u54021  \u52897 \u52376  \u51068 \u48512 \u47564  \u51096 \u46972  \u47196 \u50868 \u51060  \u47676 \u51200  \u50837 \u54620  \u44163 \u52376 \u47100  \u54140 \u46888 \u47160 \u44256 , \u48152  \u45800 \u52404  \u52292 \u54021 \u48169 \u50640 \u46020  \'93\u51172 \u46993  \u54016 \u54616 \u47732  \u49552 \u54644  \u48376 \u45796 \'94\u45716  \u47568 \u51060  \u50732 \u46972 \u50772 \u45796 . \u52404 \u50977  \u49884 \u44036  \u54016  \u44172 \u51076 \u50640 \u49436 \u46020  \u47196 \u50868 \u51008  \u51068 \u48512 \u47084  \u51228 \u50808 \u46096 \u45796 . \u47196 \u50868 \u51008  \u44172 \u51076 \u51012  \u44536 \u47564 \u46160 \u50632 \u51648 \u47564  \u54617 \u44368 \u50640 \u49436 \u51032  \u51312 \u47217 \u51008  \u44228 \u49549 \u46096 \u45796 .\
