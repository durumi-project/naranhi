\f0\b \uc0\u54788 \u51116  \u51208 \u52264  \u45800 \u44228 : \u54805 \u49324 \'b7\u48124 \u49324  \u48337 \u54665 
\f1\b0 \
\uc0\u51473 \u54617 \u44368  3\u54617 \u45380  \u49457 \u51456 \u51008  \u50728 \u46972 \u51064  \u44172 \u51076  \u50500 \u51060 \u53596  \u44144 \u47000  \u47928 \u51228 \u47196  \u44057 \u51008  \u54617 \u44368  \u54617 \u49373 \u44284  \u45796 \u53804 \u50632 \u45796 . \u49345 \u45824  \u54617 \u49373 \u51008  \'93\u54617 \u44368  \u45149 \u45208 \u44256  \u48372 \u51088 \'94\u44256  \u54664 \u44256 , \u48169 \u44284  \u54980  \u49457 \u51456 \u51012  \u54617 \u44368  \u44540 \u52376  \u45440 \u51060 \u53552 \u47196  \u48520 \u47084 \u45256 \u45796 . \u44536 \u44275 \u50640 \u45716  \u49345 \u45824  \u54617 \u49373 \u44284  \u52828 \u44396  \u54620  \u47749 \u51060  \u44592 \u45796 \u47532 \u44256  \u51080 \u50632 \u45796 .\
\uc0\u46160  \u54617 \u49373 \u51008  \u49457 \u51456 \u50640 \u44172  \u50837 \u49444 \u51012  \u54616 \u47728  \u49324 \u44284 \u54616 \u46972 \u44256  \u50836 \u44396 \u54664 \u44256 , \u49457 \u51456 \u51060  \u44144 \u51208 \u54616 \u51088  \u48128 \u52824 \u44256  \u51452 \u47673 \u51004 \u47196  \u46412 \u47160 \u45796 . \u49457 \u51456 \u51008  \u45336 \u50612 \u51648 \u47732 \u49436  \u49552 \u47785 \u51012  \u45796 \u52452 \u44256  \u50620 \u44404 \u50640 \u46020  \u47693 \u51060  \u46308 \u50632 \u45796 . \u45908  \u53360  \u47928 \u51228 \u45716  \u44032 \u54644 \u54617 \u49373  \u51473  \u54620  \u47749 \u51060  \u51060  \u51109 \u47732 \u51012  \u55092 \u45824 \u54256 \u51004 \u47196  \u52524 \u50689 \u54664 \u45796 \u45716  \u51216 \u51060 \u50632 \u45796 . \u51060 \u54980  \'93\u44620 \u48520 \u47732  \u51060 \u47111 \u44172  \u46108 \u45796 \'94\u45716  \u47568 \u44284  \u54632 \u44760  \u50689 \u49345 \u51012  \u52828 \u44396 \u46308 \u50640 \u44172  \u48372 \u50668 \u51452 \u50632 \u45796 .\
\uc0\u48372 \u54840 \u51088 \u45716  \u48337 \u50896  \u51652 \u45800 \u49436 \u50752  \u47693  \u49324 \u51652 \u51012  \u44032 \u51648 \u44256  \u54617 \u44368 \u50640  \u49888 \u44256 \u54664 \u44256 , \u46041 \u49884 \u50640  \u44221 \u52272  \u49345 \u45812 \u46020  \u51652 \u54665 \u54664 \u45796 . \u54617 \u44368 \u54253 \u47141  \u51208 \u52264 \u45716  \u49900 \u51032 \u50948 \u50896 \u54924 \u47196  \u45336 \u50612 \u44052 \u51648 \u47564 , \u48372 \u54840 \u51088 \u45716  \u54253 \u54665 , \u54801 \u48149 , \u50689 \u49345  \u50976 \u54252  \u47928 \u51228 \u50640  \u45824 \u54644  \u54805 \u49324  \u51208 \u52264 \u47484  \u48337 \u54665 \u54616 \u44256  \u51080 \u45796 . \u52824 \u47308 \u48708 \u50752  \u51221 \u49888 \u51201  \u49552 \u54644 \u50640  \u45824 \u54644 \u49436 \u45716  \u48124 \u49324 \u49345  \u49552 \u54644 \u48176 \u49345 \u46020  \u44160 \u53664  \u51473 \u51060 \u45796 .\
