\uc0\u44256 \u46321 \u54617 \u44368  2\u54617 \u45380  \u52292 \u47536 \u51008  \u50612 \u45712  \u45216  \u52828 \u44396 \u50640 \u44172 \u49436  \'93\u45320  \u51060 \u49345 \u54620  \u44228 \u51221  \u47564 \u46308 \u50632 \u50612 ?\'94\u46972 \u45716  \u47568 \u51012  \u46308 \u50632 \u45796 . \u54869 \u51064 \u54644  \u48372 \u45768  \u52292 \u47536 \u51032  \u51060 \u47492 \u44284  \u49324 \u51652 \u51012  \u49324 \u50857 \u54620  SNS \u44228 \u51221 \u51060  \u47564 \u46308 \u50612 \u51256  \u51080 \u50632 \u45796 . \u44536  \u44228 \u51221 \u50640 \u45716  \u52292 \u47536 \u51060  \u49892 \u51228 \u47196  \u54616 \u51648  \u50506 \u51008  \u47568 \u46308 \u51060  \u50732 \u46972 \u50752  \u51080 \u50632 \u45796 . \u51068 \u48512  \u44172 \u49884 \u47932 \u51008  \u52828 \u44396 \u47484  \u54744 \u45812 \u54616 \u45716  \u45236 \u50857 \u52376 \u47100  \u48372 \u51060 \u44172  \u51089 \u49457 \u46104 \u50612  \u51080 \u50632 \u45796 .\
