\uc0\u52488 \u46321 \u54617 \u44368  6\u54617 \u45380  \u53468 \u50724 \u45716  \u52404 \u50977  \u49884 \u44036 \u50640  \u45804 \u47532 \u44592 \u47484  \u54616 \u45796 \u44032  \u45336 \u50612 \u51276 \u45796 . \u47751 \u47751  \u54617 \u49373 \u46308 \u51008  \u53468 \u50724 \u47484  \u46020 \u50752 \u51452 \u44592 \u48372 \u45796  \u50883 \u51004 \u47728  \u55092 \u45824 \u54256 \u51004 \u47196  \u52524 \u50689 \u54664 \u45796 . \u44536 \u51473  \u54620  \u54617 \u49373 \u51008  \u50689 \u49345 \u51012  \u51687 \u44172  \u54200 \u51665 \u54644  \'93\u49836 \u47196 \u47784 \u49496  \u47112 \u51204 \u46300 \'94\u46972 \u45716  \u51088 \u47561 \u51012  \u48537 \u51064  \u46244  \u52828 \u44396 \u46308 \u47564  \u48372 \u45716  SNS \u44228 \u51221 \u50640  \u50732 \u47160 \u45796 .\
\uc0\u50689 \u49345 \u51008  \u52376 \u51020 \u50640 \u45716  \u47751  \u47749 \u47564  \u48420 \u51648 \u47564 , \u44263  \u45796 \u47480  \u48152  \u54617 \u49373 \u46308 \u50640 \u44172 \u46020  \u54140 \u51276 \u45796 . \u53468 \u50724 \u44032  \u48373 \u46020 \u47484  \u51648 \u45208 \u44032 \u47732  \u45572 \u44400 \u44032  \u51068 \u48512 \u47084  \u45336 \u50612 \u51648 \u45716  \u55113 \u45236 \u47484  \u45256 \u44256 , \'93\u49836 \u47196 \u47784 \u49496  \u48372 \u50668 \u51480 \'94\u46972 \u44256  \u47568 \u54664 \u45796 . \u53468 \u50724 \u45716  \u52404 \u50977  \u49884 \u44036 \u51060  \u47924 \u49436 \u50892 \u51276 \u44256 , \u54617 \u44368 \u50640 \u49436  \u46832 \u45716  \u54876 \u46041 \u51012  \u54588 \u54616 \u47140  \u54664 \u45796 .\
